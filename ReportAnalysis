                                )
                                .join("\n");

                              // 3. Combine them with a newline (\n) in between
                              const combinedData = `${headcodeRow}\n${childrenRows}`;

                              console.log("Copied Data:\n", combinedData);

                              // 4. Send the whole block to the clipboard
                              navigator.clipboard
                                .writeText(combinedData)
                                .then(() => {
                                  showSnackBar(
                                    "Text copied successfully",
                                    "success",
                                  );
                                })
                                .catch((err) => {
                                  console.error("Failed to copy text: ", err);
                                  showSnackBar("Failed to copy text", "error");
                                });
                            }}
                            sx={{ ml: 2, padding: "2px" }}
                          >
                            <ContentCopyIcon
                              sx={{ fontSize: 16, color: "text.secondary" }}
                            />
                          </IconButton>
                        </Tooltip>
                    )} */}
                  </div>
                </TableCell>
              );
            }
            return (
              <TableCell
                key={colIndex}
                style={{
                  borderRight: `1px solid ${theme.palette.divider}`,
                  borderBottom: `1px solid ${theme.palette.divider}`,
                  whiteSpace: "nowrap",
                  padding: 0,
                }}
              />
            );
          })}

          {activeMetrics.map((metric) => {
            const value = node[metric.logicalName];
            return (
              <TableCell
