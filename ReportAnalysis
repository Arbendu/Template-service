                      }}
                    >
                      {metric.displayName}
                    </TableCell>
                  ))}
                </TableRow>
              </TableHead>
              <TableBody>
                {paddingTop > 0 && (
                  <TableRow>
                    <TableCell
                      colSpan={totalColumnsCount}
                      style={{
                        height: `${paddingTop}px`,
                        padding: 0,
                        border: "none",
                      }}
                    />
                  </TableRow>
                )}

                {virtualItems.map((virtualRow) => {
                  const row = visibleRows[virtualRow.index];
                  return (
                    <ActualTreeTableRow
                      key={row.id}
                      node={row}
                      index={virtualRow.index}
                      isExpanded={expandedIds.has(row.id)}
                      isLoading={loadingIds.has(row.id)}
                      onToggle={handleToggle}
                      maxVisibleLevel={maxVisibleLevel}
                      activeMetrics={activeHierarchyConfig.availableMetrics}
                      theme={theme}
                      ref={virtualizer.measureElement}
                      data-index={virtualRow.index}
                      showSnackBar={showSnackBar}
                    />
                  );
                })}

                {paddingBottom > 0 && (
                  <TableRow>
                    <TableCell
                      col
                      colSpan={totalColumnsCount}
                      style={{
                        height: `${paddingBottom}px`,
                        padding: 0,
                        border: "none",
                      }}
                    />
                  </TableRow>
                )}
              </TableBody>
            </Table>
          ) : null}
        </TableContainer>

        <Box
          sx={{
            bgcolor: "background.paper",
            borderTop: 1,
            borderColor: "divider",
            px: 2,
            py: 1,
            display: "flex",
            justifyContent: "space-between",
            alignItems: "center",
            minHeight: 40,
          }}
        >
          <Typography variant="caption" color="text.secondary" fontWeight={500}>
            Showing {visibleRows.length} rows
          </Typography>
          <Box sx={{ display: "flex", alignItems: "center", gap: 1 }}>
            <IconButton
              onClick={toggleFullscreen}
              size="small"
              sx={{ border: "1px solid", borderColor: "divider", mr: 0.5 }}
            >
              {isFullscreen ? (
                <FullscreenExitIcon fontSize="small" />
              ) : (
                <FullscreenIcon fontSize="small" />
              )}
            </IconButton>
            <Typography
              variant="caption"
              color="text.secondary"
              sx={{ userSelect: "none" }}
            >
              {isFullscreen ? "Exit Full Screen" : "Press F to Full Screen"}
            </Typography>
          </Box>
        </Box>
      </Paper>
    </Box>
  );
}









// ********************************************* analyticsCacheSlice ************************************ //

import { createSlice } from "@reduxjs/toolkit";

const analyticsCacheSlice = createSlice({
  name: "analyticsCache",
  initialState: {
    nodes: {}, // Structure: { [cacheKey]: { data: [], timestamp: 123456789 } }
  },
  reducers: {
    cacheNode: (state, action) => {
      const { key, data, timestamp } = action.payload;
      state.nodes[key] = { data, timestamp };
    },
    // Optional: Call this on user logout or when manually refreshing reports
    clearCache: (state) => {
      state.nodes = {};
    },
  },
});

export const { cacheNode, clearCache } = analyticsCacheSlice.actions;
export default analyticsCacheSlice.reducer;
