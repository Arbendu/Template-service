      if (window.history.state?.isFullscreenOverlay) window.history.back();
    } else {
      dispatch(enterComponentFullscreen());
      showSnackBar("To exit full screen press 'F9' ", "info");
      window.history.pushState({ isFullscreenOverlay: true }, "");
    }
  }, [isFullscreen, dispatch, showSnackBar]);

  useEffect(() => {
    const handlePopState = () =>
      isFullscreen && dispatch(exitComponentFullscreen());
    window.addEventListener("popstate", handlePopState);
    return () => window.removeEventListener("popstate", handlePopState);
  }, [isFullscreen, dispatch]);

  useEffect(() => {
    const handleKeyDown = (e) => {
      if (e.target.tagName === "INPUT" || e.target.tagName === "TEXTAREA") {
        return;
      }
      if (e.key === "F9") {
        if (isFullscreen) {
          dispatch(exitComponentFullscreen());
          if (window.history.state?.isFullscreenOverlay) window.history.back();
        } else {
          dispatch(enterComponentFullscreen());
          showSnackBar("To exit full screen press 'F9' ", "info");
          window.history.pushState({ isFullscreenOverlay: true }, "");
        }
      }
    };
    window.addEventListener("keydown", handleKeyDown);
    return () => window.removeEventListener("keydown", handleKeyDown);
  }, [isFullscreen, dispatch]);

  // --- CONFIG FETCHING ---
  useEffect(() => {
    const fetchConfig = async () => {
      try {
        const response = await callApi("/AS/analytics/config", {}, "GET");
        setReportsConfig(
          Array.isArray(response) ? response : response?.data || [],
        );
        console.log("Response: ", response);
      } catch (error) {
        showSnackBar("Error fetching configuration", "error");
      }
    };
    if (user) fetchConfig();
  }, [callApi, user, showSnackBar]);

  // --- DATA FETCHING (Root Level) ---

  const handleApplyFilters = async (newFilters) => {
    setIsInitializing(true);

    try {
      // Find the specific hierarchy configuration for the selected report & view
      const targetReport = reportsConfig.find(
        (r) => r.reportCode === newFilters.reportCode,
      );
      const targetHierarchyConfig =
        targetReport?.views.find((v) => v.viewCode === newFilters.viewCode) ||
        DEFAULT_CONFIG;

      const rootData = await fetchInitialData(
        callApi,
        showSnackBar,
        newFilters,
        targetHierarchyConfig.hierarchy,
        targetHierarchyConfig.availableMetrics,
      );
      showSnackBar("Drill-Down data successfully fetched", "success");

      // If data is empty, DO NOT apply filters or close dialog. Path naturally stays hidden.
      if (!rootData || rootData.length === 0) {
        showSnackBar("No data found for the selected combination", "warning");
      } else {
        // Success: Update main view state, inject data, and close dialog
        setAppliedFilters(newFilters);
        setData(rootData);
        setExpandedIds(new Map());
        setIsFilterDialogOpen(false);
      }
    } catch (error) {
      console.error("Failed to load initial data", error);
      showSnackBar("Error fetching data", "error");
    } finally {
      setIsInitializing(false);
    }
  };

  // --- NODE EXPANSION LOGIC ---
  const appendChildrenToTree = useCallback((nodes, parentId, newChildren) => {
    return nodes.map((node) => {
      if (node.id === parentId) return { ...node, children: newChildren };
      if (node.children)
        return {
          ...node,
          children: appendChildrenToTree(node.children, parentId, newChildren),
        };
      return node;
    });
  }, []);

  const handleToggle = useCallback(
    async (node) => {
      const isExpanded = expandedIds.has(node.id);

      if (isExpanded) {
        setExpandedIds((prev) => {
          const next = new Map(prev);
          next.delete(node.id);
          const removeDescendants = (currentNode) => {
            if (currentNode.children) {
              currentNode.children.forEach((child) => {
                next.delete(child.id);
                removeDescendants(child);
              });
            }
          };
          removeDescendants(node);
          return next;
        });
      } else {
        if (!node.children && node.hasChildren) {
          const filterHash = `${appliedFilters.viewCode}_${appliedFilters.entityCode}_${appliedFilters.head.headCode}_${appliedFilters.reportDate}`;
          const cacheKey = `${filterHash}_${node.id}`;
          const cachedEntry = cachedNodes[cacheKey];
          const isCacheValid =
            cachedEntry && Date.now() - cachedEntry.timestamp < 900000;

          if (isCacheValid) {
            setData((prevData) =>
              appendChildrenToTree(prevData, node.id, cachedEntry.data),
            );
          } else {
            setLoadingIds((prev) => new Set(prev).add(node.id));
            try {
              const children = await fetchChildrenData(
                callApi,
                showSnackBar,
                node,
                appliedFilters,
                activeHierarchyConfig.hierarchy,
                activeHierarchyConfig.availableMetrics,
              );
              setData((prevData) =>
                appendChildrenToTree(prevData, node.id, children),
              );
              dispatch(
                cacheNode({
                  key: cacheKey,
                  data: children,
                  timestamp: Date.now(),
                }),
              );
            } catch (error) {
              console.error("Failed to fetch children", error);
            } finally {
              setLoadingIds((prev) => {
                const next = new Set(prev);
                next.delete(node.id);
                return next;
              });
            }
          }
        }

        setExpandedIds((prev) => {
          const next = new Map();
          prev.forEach((level, id) => {
            if (level < node.level) next.set(id, level);
          });
          next.set(node.id, node.level);
          return next;
        });
      }
    },
    [
      expandedIds,
      appendChildrenToTree,
      activeHierarchyConfig,
      appliedFilters,
      callApi,
      showSnackBar,
      cachedNodes,
      dispatch,
    ],
  );

  // --- VIRTUALIZATION ENGINE ---
  const visibleRows = useMemo(() => {
    const rows = [];
    const traverse = (nodes) => {
      for (const node of nodes) {
        rows.push(node);
        if (expandedIds.has(node.id) && node.children) traverse(node.children);
      }
    };
    traverse(data);
    return rows;
  }, [data, expandedIds]);

  const maxVisibleLevel = useMemo(() => {
    if (visibleRows.length === 0) return 0;
    return Math.max(...visibleRows.map((row) => row.level));
  }, [visibleRows]);

  const visibleHierarchyLevels = activeHierarchyConfig.hierarchy.slice(
    0,
    maxVisibleLevel + 1,
  );

  const virtualizer = useVirtualizer({
    count: visibleRows.length,
    getScrollElement: () => tableContainerRef.current,
    estimateSize: () => 40,
    overscan: 5,
  });

  const virtualItems = virtualizer.getVirtualItems();
  const totalColumnsCount =
    visibleHierarchyLevels.length +
    activeHierarchyConfig.availableMetrics.length;
  const paddingTop = virtualItems.length > 0 ? virtualItems[0].start : 0;
  const paddingBottom =
    virtualItems.length > 0
      ? virtualizer.getTotalSize() - virtualItems[virtualItems.length - 1].end
      : 0;

  return (
    <Box
      sx={{
        display: "flex",
        flexDirection: "column",
        gap: 1.5,
        ...(isFullscreen
          ? {
              position: "fixed",
              top: 0,
              left: 0,
              right: 0,
              bottom: 0,
              width: "100vw",
              height: "100vh",
              zIndex: 1299,
              p: 2,
            }
          : { height: "calc(100vh - 220px)" }),
      }}
    >
      <ReportAnalysisHeader
        activeReport={activeReport}
        isFullscreen={isFullscreen}
        toggleFullscreen={toggleFullscreen}
        onOpenFilter={() => setIsFilterDialogOpen(true)}
        filtersApplied={filtersApplied}
        appliedFilters={appliedFilters}
        onClearFilters={() => {
          setAppliedFilters({
            reportCode: "",
            viewCode: "",
            head: null,
            entityCode: "",
            entityName: "",
            reportDate: "",
          });
          setData([]);
          setExpandedIds(new Map());
          setLoadingIds(new Map());
        }}
      />

      <FilterDialog
        open={isFilterDialogOpen}
        onClose={() => setIsFilterDialogOpen(false)}
        onApply={(filters) => handleApplyFilters(filters)}
        reportsConfig={reportsConfig}
        currentFilters={appliedFilters}
        callApi={callApi}
        user={user} // Passes Redux authorized entities downward
        isApplying={isInitializing}
      />

      <Paper
        elevation={0}
        sx={{
          flexGrow: 1,
          display: "flex",
          flexDirection: "column",
          overflow: "hidden",
          borderRadius: 1,
          boxShadow: "0 2px 10px rgba(0,0,0,0.03)",
          border: 1,
          borderColor: "divider",
        }}
      >
        <Box
          sx={{
            borderBottom: 1,
            borderColor: "divider",
            px: 2,
            py: 1.5,
            minHeight: 44,
            display: "flex",
            alignItems: "center",
          }}
        >
          <HierarchyPath
            activeHierarchyConfig={activeHierarchyConfig}
            maxVisibleLevel={maxVisibleLevel}
            isSetupComplete={isSetupComplete}
          />
        </Box>

        <TableContainer
          ref={tableContainerRef}
          sx={{
            flexGrow: 1,
            bgcolor: "background.default",
            position: "relative",
            overflow: "auto",
            willChange: "transform",
          }}
        >
          {/* {!isSetupComplete && (
            <Box
              sx={{
                position: "absolute",
                top: 0,
                left: 0,
                right: 0,
                bottom: 0,
                display: "flex",
                flexDirection: "column",
                alignItems: "center",
                justifyContent: "center",
                zIndex: 10,
              }}
            >
              <DatasetIcon
                sx={{ fontSize: 64, color: "action.disabled", mb: 1 }}
              />
              <Typography variant="h6" color="text.secondary">
                No Data to Display
              </Typography>
              <Typography variant="body2" color="text.disabled">
                Click the filter icon to select a report combination and scope.
              </Typography>
            </Box>
          )} */}
          {!isSetupComplete && (
            <Box
              sx={{
                position: "absolute",
                top: 0,
                left: 0,
                right: 0,
                bottom: 0,
                display: "flex",
                flexDirection: "column",
                alignItems: "center",
                justifyContent: "center",
                zIndex: 10,
                p: 3,
                textAlign: "center",
              }}
            >
              {/* Funnel Icon Box */}
              <Box
                sx={{
                  width: 64,
                  height: 64,
                  borderRadius: 4,
                  bgcolor: "action.hover", // Light gray/blue background
                  display: "flex",
                  alignItems: "center",
                  justifyContent: "center",
                  mb: 2,
                }}
              >
                <FilterAltOutlinedIcon
                  sx={{ fontSize: 32, color: "text.secondary" }}
                />
              </Box>

              {/* Text Elements */}
              <Typography
                variant="h5"
                sx={{ color: "primary.main", fontWeight: "bold", mb: 1 }}
              >
                No Data to Display
              </Typography>
              <Typography color="primary.main" sx={{ maxWidth: 350, mb: 3 }}>
                Configure the database report, head, hierarchy and report date
                to render the drill-down matrix.
              </Typography>

              {/* Action Button */}
              <Button
                variant="contained"
                color="primary"
                startIcon={<TuneIcon />}
                onClick={() => setIsFilterDialogOpen(true)}
                sx={{
                  borderRadius: 8, // Makes it pill-shaped
                  textTransform: "none",
                  fontWeight: 600,
                  px: 3,
                }}
              >
                Open filter dialog
              </Button>
            </Box>
          )}

          {isInitializing ? (
            <Box
              sx={{
                height: "100%",
                display: "flex",
                flexDirection: "column",
                alignItems: "center",
                justifyContent: "center",
              }}
            >
              <CircularProgress size={32} color="primary" sx={{ mb: 1 }} />
              <Typography variant="body2" color="text.secondary">
                Executing Query ...
              </Typography>
            </Box>
          ) : isSetupComplete && data.length > 0 ? (
            <Table
              stickyHeader
              size="small"
              sx={{ minWidth: 1000, tableLayout: "fixed" }}
            >
              <TableHead>
                <TableRow>
                  {visibleHierarchyLevels.map((levelName) => (
                    <TableCell
                      key={levelName}
                      sx={{
                        backgroundColor:
                          theme.palette.purple?.[100] ||
                          theme.palette.primary.light,
                        color: "text.primary",
                        fontWeight: 700,
                        borderRight: 1,
                        borderColor: "divider",
                        borderBottom: 2,
                        py: 1,
                        whiteSpace: "nowrap",
                      }}
                    >
                      {levelName.replace("_", " ").toUpperCase()}
                    </TableCell>
                  ))}
                  {activeHierarchyConfig.availableMetrics.map((metric) => (
                    <TableCell
                      key={metric.logicalName}
                      align="right"
                      sx={{
                        backgroundColor:
                          theme.palette.purple?.[200] ||
                          theme.palette.primary.light,
                        color: "text.primary",
                        fontWeight: 700,
                        borderRight: 1,
                        borderColor: "divider",
                        borderBottom: 2,
                        py: 1,
                        whiteSpace: "nowrap",
                      }}
                    >
                      {metric.displayName}
                    </TableCell>
                  ))}
                </TableRow>
              </TableHead>
              <TableBody>
                {paddingTop > 0 && (
                  <TableRow>
                    <TableCell
                      colSpan={totalColumnsCount}
                      style={{
                        height: `${paddingTop}px`,
                        padding: 0,
                        border: "none",
                      }}
                    />
                  </TableRow>
                )}

                {virtualItems.map((virtualRow) => {
                  const row = visibleRows[virtualRow.index];
                  return (
                    <ActualTreeTableRow
                      key={row.id}
                      node={row}
                      index={virtualRow.index}
                      isExpanded={expandedIds.has(row.id)}
                      isLoading={loadingIds.has(row.id)}
                      onToggle={handleToggle}
                      maxVisibleLevel={maxVisibleLevel}
                      activeMetrics={activeHierarchyConfig.availableMetrics}
                      theme={theme}
                      ref={virtualizer.measureElement}
                      data-index={virtualRow.index}
                      hierarchyLength={activeHierarchyConfig.hierarchy.length}
                      showSnackBar={showSnackBar}
                      expandedIds={expandedIds}
                    />
                  );
                })}

                {paddingBottom > 0 && (
                  <TableRow>
                    <TableCell
                      col
                      colSpan={totalColumnsCount}
                      style={{
                        height: `${paddingBottom}px`,
                        padding: 0,
                        border: "none",
                      }}
                    />
                  </TableRow>
                )}
              </TableBody>
            </Table>
          ) : null}
        </TableContainer>

        <Box
          sx={{
            bgcolor: "background.paper",
            borderTop: 1,
            borderColor: "divider",
            px: 2,
            py: 1,
            display: "flex",
            justifyContent: "space-between",
            alignItems: "center",
            minHeight: 40,
          }}
        >
          <Typography variant="caption" color="text.secondary" fontWeight={500}>
            Showing {visibleRows.length} rows
          </Typography>
          <Box sx={{ display: "flex", alignItems: "center", gap: 1 }}>
            <IconButton
              onClick={toggleFullscreen}
              size="small"
              sx={{ border: "1px solid", borderColor: "divider", mr: 0.5 }}
            >
              {isFullscreen ? (
                <FullscreenExitIcon fontSize="small" />
              ) : (
                <FullscreenIcon fontSize="small" />
              )}
            </IconButton>
            <Typography
              variant="caption"
              color="text.secondary"
              sx={{ userSelect: "none" }}
            >
              {isFullscreen
                ? "Press 'F9' to Exit Full Screen"
                : "Press 'F9' to Full Screen"}
            </Typography>
          </Box>
        </Box>
      </Paper>
    </Box>
  );
}












// ********************************************* analyticsCacheSlice ************************************ //

import { createSlice } from "@reduxjs/toolkit";

const analyticsCacheSlice = createSlice({
  name: "analyticsCache",
  initialState: {
    nodes: {}, // Structure: { [cacheKey]: { data: [], timestamp: 123456789 } }
  },
  reducers: {
    cacheNode: (state, action) => {
      const { key, data, timestamp } = action.payload;
      state.nodes[key] = { data, timestamp };
    },
    // Optional: Call this on user logout or when manually refreshing reports
    clearCache: (state) => {
      state.nodes = {};
    },
  },
});

export const { cacheNode, clearCache } = analyticsCacheSlice.actions;
export default analyticsCacheSlice.reducer;
