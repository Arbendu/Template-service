    typeof headDisplay === "object"
      ? `${headDisplay.headCode || ""} - ${headDisplay.headName || ""}`
      : headDisplay;
  const cleanScope =
    typeof scopeDisplay === "object"
      ? scopeDisplay?.displayName || scopeDisplay?.viewCode
