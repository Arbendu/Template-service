                          >
                            <ContentCopyIcon
                              sx={{ fontSize: 16, color: "text.secondary" }}
                            />
                          </IconButton>
                        </Tooltip>
                      )}
                    {/* {
                      isExpanded &&
                      !isLoading &&
                      node.level === 1 &&
                      node.children && (
                        <Tooltip title="Copy all GLCODEs" placement="top" arrow>
                          <IconButton
                            size="small"
