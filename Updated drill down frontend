  useEffect(() => {
    const loadRoot = async () => {
      setIsInitializing(true);
      setData([]); 
      setExpandedIds(new Set()); 

      try {
        const rootData = await fetchInitialData(callApi, activeReportConfig.hierarchy);
        setData(rootData);
      } catch (error) {
        console.error("Failed to load initial data", error);
      } finally {
        setIsInitializing(false);
      }
    };
    loadRoot();
