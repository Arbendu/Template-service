/**
 * Generic fetch utility for the drill-down analytics endpoint.
 * Accepts the `callApi` function from the component hook to execute the request.
 */
const fetchAnalyticsData = async (callApi, payload) => {
  try {
    // 1. Prepend '/' so useApi splits the URL correctly to find the '/AS' service.
    // 2. Pass the raw payload object; Axios handles stringification.
    const responseData = await callApi(
      "/AS/analytics-reports/drill-down",
      payload,
      "POST"
    );

    // useApi returns the parsed data directly. Ensure fallback to empty array.
    return responseData?.data || []; 
  } catch (error) {
    console.error("Error fetching analytics data:", error);
    throw error;
  }
};

const fetchInitialData = async (callApi, hierarchy) => {
  const rootDimension = hierarchy[0];
  const payload = {
    dimensions: [rootDimension],
    metrics: ["jan", "feb", "mar"],
    hierarchy: hierarchy,
    filters: [],
  };

  console.log(`🚀 INITIAL LOAD [{rootDimension}] - Sending to API:`, payload);

  const apiData = await fetchAnalyticsData(callApi, payload);

  // Map the backend data to include frontend-specific tracking properties
  return apiData.map((row) => ({
    ...row,
    level: 0,
    nodeFilters: [],
  }));
};

const fetchChildrenData = async (callApi, parentNode, hierarchy) => {
  const childLevel = parentNode.level + 1;
  const nextDimension = hierarchy[childLevel];

  const currentFilters = [
    ...(parentNode.nodeFilters || []),
    {
      field: hierarchy[parentNode.level],
      operator: "EQUALS",
      value: parentNode.name,
    },
  ];

  const payload = {
    dimensions: [nextDimension],
    metrics: ["jan", "feb", "mar"],
    hierarchy: hierarchy,
    filters: currentFilters,
  };

  console.log(`📥 USER CLICKED [${parentNode.name}] - Sending to API:`, payload);

  const apiData = await fetchAnalyticsData(callApi, payload);

  // Map the backend data to include frontend-specific tracking properties
  return apiData.map((row) => ({
    ...row,
    level: childLevel,
    nodeFilters: currentFilters,
  }));
};

