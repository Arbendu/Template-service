          <Box display="flex" alignItems="center" gap={2}>
            <Box sx={{ backgroundColor: "primary.light", borderRadius: "50%", width: 50, height: 50, display: "flex", alignItems: "center", justifyContent: "center" }}>
              <AnalyticsIcon sx={{ color: "primary.contrastText", fontSize: 30 }} />
            </Box>
            <Box>
              <Typography variant="h6" sx={{ color: "primary.contrastText", fontWeight: 600 }}>
                Detailed Analytics Workspace
              </Typography>
              <Typography variant="caption" sx={{ color: "primary.contrastText", opacity: 0.8 }}>
                Dynamic Drill-Down Matrix
              </Typography>
            </Box>
          </Box>
        </Box>

        {/* Toolbar Area */}
        <Box sx={{ bgcolor: "background.glass", borderBottom: 1, borderColor: "divider", px: 3, py: 2, display: "flex", alignItems: "center", gap: 3 }}>
          <FormControl size="small" sx={{ minWidth: 250, bgcolor: "background.paper" }}>
            <InputLabel id="report-select-label">Select Report Map</InputLabel>
            <Select
              labelId="report-select-label"
              value={activeReportKey}
              label="Select Report Map"
              onChange={(e) => setActiveReportKey(e.target.value)}
            >
              {Object.values(REPORT_TYPES).map((report) => (
                <MenuItem key={report.id} value={report.id}>
                  {report.label}
                </MenuItem>
              ))}
            </Select>
          </FormControl>

          <Box sx={{ borderLeft: 1, borderColor: "divider", height: 30, mx: 1 }} />
          <Typography variant="body2" color="text.secondary">Path:</Typography>
          
          <Box display="flex" alignItems="center" gap={1}>
            {activeReportConfig.hierarchy.map((item, index) => (
               <Box key={index} display="flex" alignItems="center">
                <Typography variant="body2" fontWeight={600} color="primary.main">
                  {item}
                </Typography>
                {index < activeReportConfig.hierarchy.length - 1 && (
                  <LinkIcon sx={{ mx: 1, fontSize: 16, color: "text.secondary" }} />
                )}
              </Box>
            ))}
          </Box>
        </Box>

        {/* Material-UI Data Grid */}
        <TableContainer sx={{ flexGrow: 1, bgcolor: "background.default" }}>
          {isInitializing ? (
            <Box sx={{ height: "100%", display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "center" }}>
              <CircularProgress size={40} color="primary" sx={{ mb: 2 }} />
              <Typography variant="body1" color="text.secondary">Executing Query on Engine...</Typography>
            </Box>
          ) : (
            <Table stickyHeader size="small" sx={{ minWidth: 1000 }}>
              <TableHead>
                <TableRow>
                  {visibleHierarchyLevels.map((levelName) => (
                    <TableCell key={levelName} sx={{ bgcolor: "background.paper", color: "text.primary", fontWeight: 700, borderRight: 1, borderColor: "divider", borderBottom: 2, width: 220 }}>
                       {levelName.replace("_", " ").toUpperCase()}
                    </TableCell>
                  ))}
                  <TableCell align="right" sx={{ bgcolor: "background.paper", color: "text.primary", fontWeight: 700, borderRight: 1, borderColor: "divider", borderBottom: 2 }}>
                     January
                  </TableCell>
                  <TableCell align="right" sx={{ bgcolor: "background.paper", color: "text.primary", fontWeight: 700, borderRight: 1, borderColor: "divider", borderBottom: 2 }}>
                    February
                  </TableCell>
                  <TableCell align="right" sx={{ bgcolor: "background.paper", color: "text.primary", fontWeight: 700, borderRight: 1, borderColor: "divider", borderBottom: 2 }}>
                    March
                  </TableCell>
                  <TableCell align="right" sx={{ bgcolor: "action.hover", color: "text.primary", fontWeight: 800, borderBottom: 2, borderColor: "divider" }}>
                    YTD Total
                  </TableCell>
                </TableRow>
              </TableHead>
              <TableBody>
                {/* Render the paginated subset of rows instead of all visible rows */}
                {paginatedRows.map((row) => (
                  <TreeTableRow
                    key={row.id}
                    node={row}
                    isExpanded={expandedIds.has(row.id)}
                    isLoading={loadingIds.has(row.id)}
                    onToggle={handleToggle}
                    maxVisibleLevel={maxVisibleLevel}
                  />
                ))}
              </TableBody>
            </Table>
          )}
        </TableContainer>

        {/* Footer Status Bar with Pagination */}
        <Box sx={{ bgcolor: "background.glass", borderTop: 1, borderColor: "divider", px: 3, display: "flex", justifyContent: "space-between", alignItems: "center" }}>
          <Box sx={{ display: "flex", alignItems: "center", gap: 2 }}>
            <Box sx={{ width: 30, height: 8, borderRadius: "50%", bgcolor: "success.main" }} />
            <Typography variant="caption" color="text.secondary">Connected</Typography>
          </Box>
          
          <TablePagination
            component="div"
            count={visibleRows.length}
            page={page}
            onPageChange={handleChangePage}
            rowsPerPage={rowsPerPage}
            onRowsPerPageChange={handleChangeRowsPerPage}
            rowsPerPageOptions={[10, 25, 50, 100]}
            sx={{
              '.MuiTablePagination-toolbar': { minHeight: 50, padding: 0 },
              '.MuiTablePagination-selectLabel, .MuiTablePagination-displayedRows': { margin: 0, color: "text.secondary" }
            }}
          />
        </Box>
      </Paper>
    </Box>
  );
}
