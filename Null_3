import React, { useState } from "react";
import { Paper, Box, Stack, Typography, Collapse, TableContainer, Table, TableHead, TableRow, TableCell, TableBody } from "@mui/material";
import { alpha, useTheme } from "@mui/material/styles";
import { Public as PublicIcon, ExpandLess, ExpandMore } from "@mui/icons-material";
import { DiffText } from "./DiffText";

export const GlobalParamChangesPanel = ({ globalParamDiffs }) => {
  const theme = useTheme();
  const [globalParamsExpanded, setGlobalParamsExpanded] = useState(false);

  if (!globalParamDiffs || Object.keys(globalParamDiffs).length === 0) return null;

  return (
    <Paper variant="outlined" sx={{ overflow: "hidden", borderColor: "info.light", mt: 2 }}>
      <Box
        onClick={() => setGlobalParamsExpanded(!globalParamsExpanded)}
        sx={{
          bgcolor: alpha(theme.palette.info.main, 0.08), px: 2, py: 1.5, cursor: "pointer",
          display: "flex", justifyContent: "space-between", alignItems: "center",
        }}
      >
        <Stack direction="row" spacing={1} alignItems="center">
