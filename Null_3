import React, { useState, useEffect, useMemo, useCallback } from "react";
import { Box, Typography, Stack, Tooltip, IconButton } from "@mui/material";
import InfoIcon from "@mui/icons-material/Info";
import { DataGrid } from "@mui/x-data-grid";
import { Visibility, PendingActions, CheckCircle, Cancel } from "@mui/icons-material";
import AddBoxIcon from "@mui/icons-material/AddBox";
import AutoDeleteIcon from "@mui/icons-material/AutoDelete";
import EditDocumentIcon from "@mui/icons-material/EditDocument";
import { useSelector } from "react-redux";

import useApi from "../../../../hooks/useApi"; // Adjust path as needed
import useCustomSnackbar from "../../../../utils/useCustomSnackbar"; // Adjust path as needed
import CustomChip from "../../../../utils/CustomChip"; // Adjust path as needed
import { timeStampFormatter } from "../../../../utils/CommonUtilities"; // Adjust path as needed

import TemplateRequestAnalytics from "../analytics/TemplateRequestAnalytics";
import ViewRequestDialog from "../dialogs/ViewRequestDialog";
import CompareTemplateDialog from "../dialogs/CompareTemplateDialog/CompareTemplateDialog";
import { styles } from "../../TemplateRequestScreenStyles";

export default function MyRequestsTab() {
  const selectedMenuItem = useSelector((s) => s.menus.selectedMenuItem);
  const requestType = selectedMenuItem?.requestType || "";
  const { callApi } = useApi();
  const showSnackBar = useCustomSnackbar();

  const [dataGridLoading, setDataGridLoading] = useState(true);
  const [rows, setRows] = useState([]);
  
  const [viewOpen, setViewOpen] = useState(false);
  const [viewData, setViewData] = useState(null);
  const [compareOpen, setCompareOpen] = useState(false);
  const [selectedRequestId, setSelectedRequestId] = useState(null);

  const fetchData = useCallback(async () => {
    if (!requestType) return;
    try {
      const response = await callApi("/CR/my-requests", { requestType }, "POST");
      const result = response?.data || response || [];
      const data = result.map((row) => ({
        ...row,
        ...(typeof row.payload === "object" ? row.payload : {}),
      }));
      setRows(data);
    } catch (err) {
      console.error(err);
      showSnackBar("Error fetching my requests", "error");
    } finally {
      setDataGridLoading(false);
    }
  }, [callApi, showSnackBar, requestType]);

  useEffect(() => {
    fetchData();
  }, [fetchData]);

  const handleViewClick = (data) => {
    if (data.changeType === "UPDATE") {
      setSelectedRequestId(data.id);
      setCompareOpen(true);
    } else {
      setViewData(data);
      setViewOpen(true);
    }
  };

  const getStatusDetails = (status) => {
    switch (status) {
      case "ACCEPTED": return { color: "success", icon: <CheckCircle />, label: "Approved" };
      case "REJECTED": return { color: "error", icon: <Cancel />, label: "Rejected" };
      default: return { color: "warning", icon: <PendingActions />, label: "Pending" };
    }
  };

  const allColumns = useMemo(() => [
    { field: "reportId", headerName: "Report Id", flex: 0.5 },
    { field: "reportName", headerName: "Report Name", flex: 1.2 },
    {
      field: "changeType", headerName: "Request Type", flex: 0.6,
      renderCell: (p) => (
        <CustomChip
          icon={p.value === "ADD" ? <AddBoxIcon /> : p.value === "DELETE" ? <AutoDeleteIcon /> : <EditDocumentIcon />}
          label={p.value === "ADD" ? "Added" : p.value === "DELETE" ? "Deleted" : "Modified"}
          color={p.value === "ADD" ? "success" : p.value === "DELETE" ? "error" : "info"}
          size="small" variant="outlined"
        />
      ),
    },
    {
      field: "reqStatus", headerName: "Status", flex: 0.8,
      renderCell: (p) => {
        const { color, icon, label } = getStatusDetails(p.value);
        return <CustomChip icon={icon} size="small" color={color} label={label} variant="filled" />;
      },
    },
    {
      field: "reqDate", headerName: "Submitted Date", flex: 1,
      renderCell: (p) => <Typography variant="body2">{timeStampFormatter(p.value)}</Typography>,
    },
    {
      field: "actions", headerName: "Actions", flex: 0.5,
      renderCell: (p) => (
        <Stack direction="row" spacing={1} alignItems="center" justifyContent="center">
          <Tooltip title="View Request Details">
            <IconButton color="primary" onClick={() => handleViewClick(p.row)}>
              <Visibility />
            </IconButton>
          </Tooltip>
        </Stack>
      ),
    },
  ], []);

  return (
    <Box>
      <TemplateRequestAnalytics data={rows} />
      <DataGrid
        rows={rows} columns={allColumns} loading={dataGridLoading} disableRowSelectionOnClick
        pageSizeOptions={[5, 10, 25, 50]}
        initialState={{ pagination: { paginationModel: { pageSize: 5 } }, sorting: { sortModel: [{ field: "reqDate", sort: "desc" }] } }}
        getRowId={(row) => row.id} sx={styles.dataGrid}
        slots={{
          noRowsOverlay: () => (
            <Stack height="100%" alignItems="center" justifyContent="center">
              <InfoIcon sx={{ fontSize: 48, color: "text.secondary", mb: 2 }} />
              <Typography variant="h6">No Requests Found</Typography>
              <Typography variant="body2" color="text.secondary">You have not created any requests yet.</Typography>
            </Stack>
          ),
        }}
      />

      <ViewRequestDialog open={viewOpen} handleClose={() => { setViewOpen(false); setViewData(null); }} data={viewData} />
      <CompareTemplateDialog open={compareOpen} requestId={selectedRequestId} onClose={() => { setCompareOpen(false); setSelectedRequestId(null); }} />
    </Box>
  );
}







