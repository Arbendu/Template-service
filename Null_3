          <Typography variant="subtitle2" fontWeight="bold" color="text.primary">Global Parameter Changes</Typography>
        </Stack>
        {globalParamsExpanded ? <ExpandLess /> : <ExpandMore />}
      </Box>

      <Collapse in={globalParamsExpanded}>
        <TableContainer sx={{ maxHeight: 300 }}>
          <Table size="small" stickyHeader>
            <TableHead>
              <TableRow>
                <TableCell sx={{ fontWeight: "bold", width: "15%", backgroundColor: theme.palette.grey[50], zIndex: 10 }}>Param Name</TableCell>
                <TableCell sx={{ fontWeight: "bold", width: "20%", backgroundColor: theme.palette.grey[50], zIndex: 10 }}>Property</TableCell>
                <TableCell sx={{ fontWeight: "bold", width: "32%", color: "error.main", backgroundColor: theme.palette.grey[50] }}>Old Value</TableCell>
                <TableCell sx={{ fontWeight: "bold", width: "32%", color: "success.main", backgroundColor: theme.palette.grey[50] }}>New Value</TableCell>
              </TableRow>
            </TableHead>
            <TableBody>
              {Object.entries(globalParamDiffs).flatMap(([paramName, fields]) =>
                Object.entries(fields).map(([field, diff]) => (
                  <TableRow key={`${paramName}-${field}`} hover>
                    <TableCell sx={{ fontWeight: "bold", color: "primary.main" }}>{paramName}</TableCell>
                    <TableCell>{field}</TableCell>
                    <TableCell sx={{ bgcolor: alpha(theme.palette.error.main, 0.02) }}>
                      <DiffText value={diff.oldValue} otherValue={diff.newValue} type="old" />
                    </TableCell>
                    <TableCell sx={{ bgcolor: alpha(theme.palette.success.main, 0.02) }}>
                      <DiffText value={diff.newValue} otherValue={diff.oldValue} type="new" />
                    </TableCell>
                  </TableRow>
                ))
              )}
            </TableBody>
          </Table>
        </TableContainer>
      </Collapse>
    </Paper>
  );
};







