import React, { useState } from "react";
import { Box, Tabs, Tab, Paper } from "@mui/material";
import PendingRequestsTab from "./components/tabs/PendingRequestsTab";
import MyRequestsTab from "./components/tabs/MyRequestsTab";
import { styles } from "./TemplateRequestScreenStyles";

export default function TemplateRequestScreen() {
  const [tabIndex, setTabIndex] = useState(0);

  const handleTabChange = (event, newValue) => {
    setTabIndex(newValue);
  };

  return (
    <Box sx={styles.container}>
      <Paper sx={{ mb: 2, borderRadius: 1 }}>
        <Tabs 
          value={tabIndex} 
          onChange={handleTabChange} 
          indicatorColor="primary" 
          textColor="primary"
          sx={{ px: 2, pt: 1 }}
        >
          <Tab label="Pending Requests (To Action)" sx={{ fontWeight: 'bold' }} />
          <Tab label="My Requests" sx={{ fontWeight: 'bold' }} />
        </Tabs>
      </Paper>

      {/* Tab Panels */}
      {tabIndex === 0 && <PendingRequestsTab />}
      {tabIndex === 1 && <MyRequestsTab />}
    </Box>
  );
}








