onClick={(e) => {
  e.stopPropagation();

  // 1. Find the length of the longest GLCODE name in this specific group
  const maxLength = Math.max(...node.children.map(child => child.name.length));

  // 2. Map through and pad every name to match the longest one, plus a 5-space buffer
  const combinedData = node.children
    .map((child) => {
      // padEnd adds spaces until the string reaches the target length
      const alignedName = child.name.padEnd(maxLength + 5, " ");
      return `${alignedName}${child.TotalAmount}`;
    })
    .join("\n");

  console.log("Copied Data:\n", combinedData);

  navigator.clipboard.writeText(combinedData)
    .then(() => {
      showSnackBar("Text copied successfully", "success");
    })
    .catch((err) => {
      console.error("Failed to copy text: ", err);
      showSnackBar("Failed to copy text", "error");
    });
}}






onClick={(e) => {
  e.stopPropagation(); // Prevents row toggle when clicking the copy button

  // 1. Format the parent (Headcode) row
  // We use node.name and node.TotalAmount for the parent
  const headcodeRow = `${node.name}\t${node.TotalAmount || ""}`;

  // 2. Format the children (GLCODEs) rows
  const childrenRows = node.children
    .map((child) => `${child.name}\t${child.TotalAmount || ""}`)
    .join("\n");

  // 3. Combine them with a newline (\n) in between
  const combinedData = `${headcodeRow}\n${childrenRows}`;

  console.log("Copied Data:\n", combinedData);

  // 4. Send the whole block to the clipboard
  navigator.clipboard.writeText(combinedData)
    .then(() => {
      showSnackBar("Text copied successfully", "success");
    })
    .catch((err) => {
      console.error("Failed to copy text: ", err);
      showSnackBar("Failed to copy text", "error");
    });
}}
