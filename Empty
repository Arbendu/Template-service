          </IconButton>
        </Tooltip>

        <Tooltip title={isFullscreen ? "Exit Full Screen (Esc)" : "Full Screen"} arrow placement="bottom">
          <IconButton onClick={toggleFullscreen} sx={{ border: "1px solid", borderColor: "divider" }}>
            {isFullscreen ? <FullscreenExitIcon /> : <FullscreenIcon />}
          </IconButton>
        </Tooltip>
      </Box>
    </Paper>
  );
}










