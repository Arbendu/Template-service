import React, { memo, forwardRef } from "react";
import { TableRow, TableCell, CircularProgress } from "@mui/material";
import { formatCurrency } from "../utils/analyticsConstants";
import ContentCopyIcon from "@mui/icons-material/ContentCopy";
import { IconButton, Tooltip } from "@mui/material";

const ActualTreeTableRow = memo(
  forwardRef(
    (
      {
        node,
        isExpanded,
        isLoading,
        onToggle,
        maxVisibleLevel,
        index,
        activeMetrics,
        theme,
        isFullscreen,
        showSnackBar,
        ...props
      },
      ref,
    ) => {
      const isRoot = node.level === 0;

      return (
        <TableRow
          ref={ref}
          hover
          style={{
            backgroundColor: isExpanded
              ? theme.palette.purple?.[100] || "inherit"
              : "inherit",
            borderLeft: isExpanded
              ? `4px solid ${theme.palette.primary.main}`
              : "4px solid transparent",
            height: "40px",
            transition:
              "background-color 0.2s ease-in-out, border-color 0.2s ease-in-out",
          }}
          {...props}
        >
          {Array.from({ length: maxVisibleLevel + 1 }).map((_, colIndex) => {
            if (colIndex === node.level) {
              return (
                <TableCell
                  key={colIndex}
                  style={{
                    borderRight: `1px solid ${theme.palette.divider}`,
                    borderBottom: `1px solid ${theme.palette.divider}`,
                    //minWidth: "260px",
                    whiteSpace: "nowrap",
                    padding: "4px 4px",
                    verticalAlign: "middle",
                  }}
                >
                  <div
                    style={{
                      display: "flex",
                      alignItems: "center",
                      // paddingLeft: `${node.level * 10 + 8}px`,
                      paddingLeft: 4,
                      paddingRight: "16px",
                      width: "100%",
                      boxSizing: "border-box",
                    }}
                  >
                    {node.hasChildren ? (
                      <button
                        onClick={(e) => {
                          e.stopPropagation();
                          onToggle(node);
                        }}
                        disabled={isLoading}
                        style={{
                          marginRight: "8px",
                          padding: 0,
                          width: "20px",
                          height: "20px",
                          border: `1px solid ${isExpanded ? theme.palette.primary.main : theme.palette.divider}`,
                          borderRadius: "50%",
                          backgroundColor: "transparent",
                          cursor: isLoading ? "wait" : "pointer",
                          display: "flex",
                          alignItems: "center",
                          justifyContent: "center",
                          color: isExpanded
                            ? theme.palette.primary.main
                            : "inherit",
                          fontSize: "14px",
                          lineHeight: 1,
                          transition: "all 0.15s ease",
                        }}
                        onMouseOver={(e) =>
                          (e.currentTarget.style.transform = "scale(1.15)")
                        }
                        onMouseOut={(e) =>
                          (e.currentTarget.style.transform = "scale(1)")
                        }
                      >
                        {isLoading ? (
                          <CircularProgress
                            size={12}
                            color={isExpanded ? "primary.dark" : "inherit"}
                          />
                        ) : isExpanded ? (
                          "-"
                        ) : (
                          "+"
                        )}
                      </button>
                    ) : (
                      <div style={{ width: "28px" }} />
                    )}
                    <span
                      style={{
                        fontWeight: isExpanded ? 700 : isRoot ? 600 : 400,
                        color: isExpanded
                          ? theme.palette.primary.main
                          : "inherit",
                        whiteSpace: "nowrap",
                        overflow: "hidden",
                        textOverflow: "ellipsis",
                        fontSize: "0.875rem",
                        fontFamily:
                          theme.typography.fontFamily ||
                          "Roboto, Helvetica, Arial, sans-serif",
                      }}
                    >
                      {node.name}
                    </span>

                    {/* Checks if it's fullscreen, expanded, data is loaded, and targets HeadCode (level 1) */}
                    {
                      isExpanded &&
                      !isLoading &&
                      node.level === 1 &&
                      node.children && (
                        <Tooltip title="Copy all GLCODEs" placement="top" arrow>
                          <IconButton
                            size="small"
                            onClick={(e) => {
                              e.stopPropagation(); // Prevents row toggle when clicking the copy button

                              // 1. Format the parent (Headcode) row
                              // We use node.name and node.TotalAmount for the parent
                              const headcodeRow = `${node.name}\t${node.TotalAmount || ""}`;

                              // 2. Format the children (GLCODEs) rows
                              const childrenRows = node.children
                                .map(
                                  (child) =>
                                    `${child.name}\t${child.TotalAmount || ""}`,
                                )
                                .join("\n");

                              // 3. Combine them with a newline (\n) in between
                              const combinedData = `${headcodeRow}\n${childrenRows}`;

                              console.log("Copied Data:\n", combinedData);

                              // 4. Send the whole block to the clipboard
                              navigator.clipboard
                                .writeText(combinedData)
                                .then(() => {
                                  showSnackBar(
                                    "Text copied successfully",
                                    "success",
                                  );
                                })
                                .catch((err) => {
                                  console.error("Failed to copy text: ", err);
                                  showSnackBar("Failed to copy text", "error");
                                });
                            }}
                            sx={{ ml: 2, padding: "2px" }}
                          >
                            <ContentCopyIcon
                              sx={{ fontSize: 16, color: "text.secondary" }}
                            />
                          </IconButton>
                        </Tooltip>
                      )}
                  </div>
                </TableCell>
              );
            }
            return (
              <TableCell
                key={colIndex}
                style={{
                  borderRight: `1px solid ${theme.palette.divider}`,
                  borderBottom: `1px solid ${theme.palette.divider}`,
                  whiteSpace: "nowrap",
                  padding: 0,
                }}
              />
            );
          })}

          {activeMetrics.map((metric) => {
            const value = node[metric.logicalName];
            return (
              <TableCell
                key={metric.logicalName}
                align="right"
                style={{
                  borderRight: `1px solid ${theme.palette.divider}`,
                  borderBottom: `1px solid ${theme.palette.divider}`,
                  // width: "160px",
                  // minWidth: "160px",
                  // maxWidth: "160px",
                  //padding: "8px 16px",
                  color:
                    value < 0
                      ? theme.palette.error.main
                      : theme.palette.success.main,
                  fontWeight: 500,
                  whiteSpace: "nowrap",
                  verticalAlign: "middle",
                  fontSize: "0.875rem",
                  fontFamily:
                    theme.typography.fontFamily ||
                    "Roboto, Helvetica, Arial, sans-serif",
                }}
              >
                {formatCurrency(value)}
              </TableCell>
            );
          })}
        </TableRow>
      );
    },
  ),
  (prevProps, nextProps) => {
    return (
      prevProps.isExpanded === nextProps.isExpanded &&
      prevProps.isLoading === nextProps.isLoading &&
      prevProps.node.id === nextProps.node.id &&
      prevProps.maxVisibleLevel === nextProps.maxVisibleLevel &&
      prevProps.index === nextProps.index &&
      prevProps.theme === nextProps.theme 
      // prevProps.isFullscreen === nextProps.isFullscreen
    );
  },
);

ActualTreeTableRow.displayName = "ActualTreeTableRow";
export default ActualTreeTableRow;







