import React, {
  useState,
  useMemo,
  useCallback,
  useEffect,
  useRef,
} from "react";
import { useSelector, useDispatch } from "react-redux";
import {
  Box,
  Paper,
  Table,
  TableBody,
  TableCell,
  TableContainer,
  TableHead,
  TableRow,
  Typography,
  CircularProgress,
  Tooltip,
  IconButton,
} from "@mui/material";
import DatasetIcon from "@mui/icons-material/Dataset";
import { useTheme } from "@mui/material/styles";
import { useVirtualizer } from "@tanstack/react-virtual";

// --- REDUX UI ACTIONS ---
// Update this path if your uiSlice is located somewhere else
import {
  enterComponentFullscreen,
  exitComponentFullscreen,
} from "../../store/slices/uiSlice";

// --- HOOKS ---
import useApi from "../../hooks/useApi";
import useCustomSnackbar from "../../utils/useCustomSnackbar";

// --- COMPONENTS & UTILS ---
import ReportAnalysisHeader from "./components/ReportAnalysisHeader";
import HierarchyPath from "./components/HierarchyPath";
import ActualTreeTableRow from "./components/ActualTreeTableRow";
import FilterDialog from "./components/FilterDialog";
import { fetchInitialData, fetchChildrenData } from "./api/analyticsApi";
import { DEFAULT_CONFIG } from "./utils/analyticsConstants";

import TuneIcon from "@mui/icons-material/Tune";
import FullscreenIcon from "@mui/icons-material/Fullscreen";
import FullscreenExitIcon from "@mui/icons-material/FullscreenExit";

export default function ReportAnalysisScreen() {
  const { callApi } = useApi();
  const dispatch = useDispatch();
  const theme = useTheme();
  const tableContainerRef = useRef(null);
  const showSnackBar = useCustomSnackbar();

  const user = useSelector((state) => state.auth.user);

  // Fullscreen state managed strictly via Redux UI Slice
  const isFullscreen = useSelector(
    (state) => state.ui?.isComponentFullscreen || false,
  );
  const cachedNodes = useSelector((state) => state.analyticsCache?.nodes || {});

  // --- STATE ---
  const [reportsConfig, setReportsConfig] = useState([]);
  const [isFilterDialogOpen, setIsFilterDialogOpen] = useState(false);

  // Master Filter State (Applied Filters via Dialog)
  const [appliedFilters, setAppliedFilters] = useState({
    reportCode: "",
    head: null,
    scope: "",
    entityCode: "",
    reportDate: "",
  });

  const [data, setData] = useState([]);
  const [expandedIds, setExpandedIds] = useState(new Map());
  const [loadingIds, setLoadingIds] = useState(new Set());
  const [isInitializing, setIsInitializing] = useState(false);
  const [filtersApplied, setFiltersApplied] = React.useState(false);

  // --- DERIVED VALUES ---
  const activeReport = useMemo(() => {
    return (
      reportsConfig.find((r) => r.reportCode === appliedFilters.reportCode) ||
      null
    );
  }, [reportsConfig, appliedFilters.reportCode]);

  // Fallback to DEFAULT_CONFIG until the dynamic Scope-based hierarchy API is fully implemented
  const activeHierarchyConfig = DEFAULT_CONFIG;

  const isSetupComplete = !!(
    appliedFilters.reportCode &&
    appliedFilters.head &&
    appliedFilters.scope &&
    appliedFilters.reportDate
  );

  // --- REDUX FULLSCREEN LOGIC ---
  const toggleFullscreen = useCallback(() => {
    if (isFullscreen) {
      dispatch(exitComponentFullscreen());
      if (window.history.state && window.history.state.isFullscreenOverlay) {
        window.history.back();
      }
    } else {
      dispatch(enterComponentFullscreen());
      showSnackBar("To exit full screen press 'F' or 'Esc'", "info");
      window.history.pushState({ isFullscreenOverlay: true }, "");
    }
  }, [isFullscreen, dispatch, showSnackBar]);

  useEffect(() => {
    const handlePopState = () => {
      if (isFullscreen) {
        dispatch(exitComponentFullscreen());
      }
    };
    window.addEventListener("popstate", handlePopState);
    return () => window.removeEventListener("popstate", handlePopState);
  }, [isFullscreen, dispatch]);

  useEffect(() => {
    const handleKeyDown = (e) => {
      if (e.key === "f" && isFullscreen) {
        dispatch(exitComponentFullscreen());
        if (window.history.state && window.history.state.isFullscreenOverlay) {
          window.history.back();
        }
      }
      if (e.key === "f" && !isFullscreen) {
        dispatch(enterComponentFullscreen());
        window.history.pushState({ isFullscreenOverlay: true }, "");
        showSnackBar("To exit full screen press 'F' or 'Esc'", "info");
      }
    };
    window.addEventListener("keydown", handleKeyDown);
    return () => window.removeEventListener("keydown", handleKeyDown);
  }, [isFullscreen, dispatch, showSnackBar]);

  // --- CONFIG FETCHING ---
  useEffect(() => {
    const fetchConfig = async () => {
      try {
        const response = await callApi("/AS/analytics/config", {}, "GET");
        const configData = Array.isArray(response)
          ? response
          : response?.data || [];
        setReportsConfig(configData);
      } catch (error) {
        console.error("Failed to fetch analytics configurations", error);
        showSnackBar("Error fetching configuration", "error");
      }
    };
    if (user) fetchConfig();
  }, [callApi, user, showSnackBar]);

  // --- DATA FETCHING (Root Level) ---
  useEffect(() => {
    const loadRoot = async () => {
      if (!isSetupComplete) {
        setData((prev) => (prev.length === 0 ? prev : []));
        return;
      }
      setIsInitializing(true);
      setData([]);
      setExpandedIds(new Map());

      try {
        const rootData = await fetchInitialData(
          callApi,
          showSnackBar,
          appliedFilters, // Replaced selectedViewCode with the entire filters object
          activeHierarchyConfig.hierarchy,
          activeHierarchyConfig.availableMetrics,
        );

        if (!rootData || rootData.length === 0) {
          showSnackBar("No data found for the selected combination", "warning");
        }

        setData(rootData || []);
      } catch (error) {
        console.error("Failed to load initial data", error);
      } finally {
        setIsInitializing(false);
      }
    };
    loadRoot();
  }, [
    appliedFilters,
    activeHierarchyConfig,
    callApi,
    showSnackBar,
    isSetupComplete,
  ]);

  // --- NODE EXPANSION LOGIC ---
  const appendChildrenToTree = useCallback((nodes, parentId, newChildren) => {
    return nodes.map((node) => {
      if (node.id === parentId) return { ...node, children: newChildren };
      if (node.children) {
        return {
          ...node,
          children: appendChildrenToTree(node.children, parentId, newChildren),
        };
      }
      return node;
    });
  }, []);

  const handleToggle = useCallback(
    async (node) => {
      const isExpanded = expandedIds.has(node.id);

      if (isExpanded) {
        // Manual Collapse
        setExpandedIds((prev) => {
          const next = new Map(prev);
          next.delete(node.id);

          const removeDescendants = (currentNode) => {
            if (currentNode.children) {
              currentNode.children.forEach((child) => {
                next.delete(child.id);
                removeDescendants(child);
              });
            }
          };
          removeDescendants(node);
          return next;
        });
      } else {
        // Expansion
        if (!node.children && node.hasChildren) {
          // Utilizing scope and date in the cache key to prevent data crossover
          const cacheKey = `${appliedFilters.scope}_${node.id}_${appliedFilters.reportDate}`;
          const cachedEntry = cachedNodes[cacheKey];
          const isCacheValid =
            cachedEntry && Date.now() - cachedEntry.timestamp < 900000;

          if (isCacheValid) {
            setData((prevData) =>
              appendChildrenToTree(prevData, node.id, cachedEntry.data),
            );
          } else {
            setLoadingIds((prev) => new Set(prev).add(node.id));
            try {
              const children = await fetchChildrenData(
                callApi,
                showSnackBar,
                node,
                appliedFilters, // Replaced selectedViewCode with the entire filters object
                activeHierarchyConfig.hierarchy,
                activeHierarchyConfig.availableMetrics,
              );
              setData((prevData) =>
                appendChildrenToTree(prevData, node.id, children),
              );
              dispatch({
                type: "analyticsCache/cacheNode",
                payload: {
                  key: cacheKey,
                  data: children,
                  timestamp: Date.now(),
                },
              });
            } catch (error) {
              console.error("Failed to fetch children", error);
            } finally {
              setLoadingIds((prev) => {
                const next = new Set(prev);
                next.delete(node.id);
                return next;
              });
            }
          }
        }

        // Auto-Collapse Sibling Logic
        setExpandedIds((prev) => {
          const next = new Map();
          prev.forEach((level, id) => {
            if (level < node.level) {
              next.set(id, level);
            }
          });
          next.set(node.id, node.level);
          return next;
        });
      }
    },
    [
      expandedIds,
      appendChildrenToTree,
      activeHierarchyConfig,
      appliedFilters,
      callApi,
      showSnackBar,
      cachedNodes,
      dispatch,
    ],
  );

  // --- VIRTUALIZATION ENGINE ---
  const visibleRows = useMemo(() => {
    const rows = [];
    const traverse = (nodes) => {
      for (const node of nodes) {
        rows.push(node);
        if (expandedIds.has(node.id) && node.children) traverse(node.children);
      }
    };
    traverse(data);
    return rows;
  }, [data, expandedIds]);

  const maxVisibleLevel = useMemo(() => {
    if (visibleRows.length === 0) return 0;
    return Math.max(...visibleRows.map((row) => row.level));
  }, [visibleRows]);

  const visibleHierarchyLevels = activeHierarchyConfig.hierarchy.slice(
    0,
    maxVisibleLevel + 1,
  );

  const virtualizer = useVirtualizer({
    count: visibleRows.length,
    getScrollElement: () => tableContainerRef.current,
    estimateSize: () => 40,
    overscan: 5,
  });

  const virtualItems = virtualizer.getVirtualItems();
  const totalColumnsCount =
    visibleHierarchyLevels.length +
    activeHierarchyConfig.availableMetrics.length;
  const paddingTop = virtualItems.length > 0 ? virtualItems[0].start : 0;
  const paddingBottom =
    virtualItems.length > 0
      ? virtualizer.getTotalSize() - virtualItems[virtualItems.length - 1].end
      : 0;

  return (
    <Box
      sx={{
        display: "flex",
        flexDirection: "column",
        gap: 1.5,
        ...(isFullscreen
          ? {
              position: "fixed",
              top: 0,
              left: 0,
              right: 0,
              bottom: 0,
              width: "100vw",
              height: "100vh",
              zIndex: 1299,
              p: 2,
            }
          : {
              height: "calc(100vh - 220px)",
            }),
      }}
    >
      {/* ================= UPPER BOX / HEADER ================= */}
      <ReportAnalysisHeader
        activeReport={activeReport}
        isFullscreen={isFullscreen}
        toggleFullscreen={toggleFullscreen}
        onOpenFilter={() => setIsFilterDialogOpen(true)}
        filtersApplied={filtersApplied}
      />

      {/* ================= FILTER DIALOG ================= */}
      <FilterDialog
        open={isFilterDialogOpen}
        onClose={() => setIsFilterDialogOpen(false)}
        onApply={(newFilters) => setAppliedFilters(newFilters)}
        reportsConfig={reportsConfig}
        currentFilters={appliedFilters}
      />

      {/* ================= LOWER BOX / DATA TABLE ================= */}
      <Paper
        elevation={0}
        sx={{
          flexGrow: 1,
          display: "flex",
          flexDirection: "column",
          overflow: "hidden",
          borderRadius: 1,
          boxShadow: "0 2px 10px rgba(0,0,0,0.03)",
          border: 1,
          borderColor: "divider",
        }}
      >
        <Box
          sx={{
            borderBottom: 1,
            borderColor: "divider",
            px: 2,
            py: 1.5,
            minHeight: 44,
            display: "flex",
            alignItems: "center",
          }}
        >
          <HierarchyPath
            activeHierarchyConfig={activeHierarchyConfig}
            maxVisibleLevel={maxVisibleLevel}
            isSetupComplete={isSetupComplete}
          />
        </Box>

        <TableContainer
          ref={tableContainerRef}
          sx={{
            flexGrow: 1,
            bgcolor: "background.default",
            position: "relative",
            overflow: "auto",
            willChange: "transform",
          }}
        >
          {!isSetupComplete && (
            <Box
              sx={{
                position: "absolute",
                top: 0,
                left: 0,
                right: 0,
                bottom: 0,
                display: "flex",
                flexDirection: "column",
                alignItems: "center",
                justifyContent: "center",
                zIndex: 10,
              }}
            >
              <DatasetIcon
                sx={{ fontSize: 64, color: "action.disabled", mb: 1 }}
              />
              <Typography variant="h6" color="text.secondary">
                No Data to Display
              </Typography>
              <Typography variant="body2" color="text.disabled">
                Click the filter icon to select a report combination and scope.
              </Typography>
            </Box>
          )}

          {isInitializing ? (
            <Box
              sx={{
                height: "100%",
                display: "flex",
                flexDirection: "column",
                alignItems: "center",
                justifyContent: "center",
              }}
            >
              <CircularProgress size={32} color="primary" sx={{ mb: 1 }} />
              <Typography variant="body2" color="text.secondary">
                Executing Query ...
              </Typography>
            </Box>
          ) : isSetupComplete && data.length > 0 ? (
            <Table
              stickyHeader
              size="small"
              sx={{ minWidth: 1000, tableLayout: "fixed" }}
            >
              <TableHead>
                <TableRow>
                  {visibleHierarchyLevels.map((levelName) => (
                    <TableCell
                      key={levelName}
                      sx={{
                        backgroundColor:
                          theme.palette.purple?.[100] ||
                          theme.palette.primary.light,
                        color: "text.primary",
                        fontWeight: 700,
                        borderRight: 1,
                        borderColor: "divider",
                        borderBottom: 2,
                        py: 1,
                        whiteSpace: "nowrap",
                      }}
                    >
                      {levelName.replace("_", " ").toUpperCase()}
                    </TableCell>
                  ))}
                  {activeHierarchyConfig.availableMetrics.map((metric) => (
                    <TableCell
                      key={metric.logicalName}
                      align="right"
                      sx={{
                        backgroundColor:
                          theme.palette.purple?.[200] ||
                          theme.palette.primary.light,
                        color: "text.primary",
                        fontWeight: 700,
                        borderRight: 1,
                        borderColor: "divider",
                        borderBottom: 2,
                        py: 1,
                        whiteSpace: "nowrap",
                      }}
                    >
                      {metric.displayName}
                    </TableCell>
                  ))}
                </TableRow>
              </TableHead>
              <TableBody>
                {/* Virtualization top spacing */}
                {paddingTop > 0 && (
                  <TableRow>
                    <TableCell
                      colSpan={totalColumnsCount}
                      style={{
                        height: `${paddingTop}px`,
                        padding: 0,
                        border: "none",
                      }}
                    />
                  </TableRow>
                )}

                {virtualItems.map((virtualRow) => {
                  const row = visibleRows[virtualRow.index];
                  return (
                    <ActualTreeTableRow
                      key={row.id}
                      node={row}
                      index={virtualRow.index}
                      isExpanded={expandedIds.has(row.id)}
                      isLoading={loadingIds.has(row.id)}
                      onToggle={handleToggle}
                      maxVisibleLevel={maxVisibleLevel}
                      activeMetrics={activeHierarchyConfig.availableMetrics}
                      theme={theme}
                      ref={virtualizer.measureElement}
                      data-index={virtualRow.index}
                    />
                  );
                })}

                {/* Virtualization bottom spacing */}
                {paddingBottom > 0 && (
                  <TableRow>
                    <TableCell
                      colSpan={totalColumnsCount}
                      style={{
                        height: `${paddingBottom}px`,
                        padding: 0,
                        border: "none",
                      }}
                    />
                  </TableRow>
                )}
              </TableBody>
            </Table>
          ) : null}
        </TableContainer>

        <Box
          sx={{
            bgcolor: "background.paper",
            borderTop: 1,
            borderColor: "divider",
            px: 2,
            py: 1, // Added vertical padding for better spacing
            display: "flex",
            justifyContent: "space-between",
            alignItems: "center",
            minHeight: 40,
          }}
        >
          {/* Left Side: Row Count */}
          <Typography variant="caption" color="text.secondary" fontWeight={500}>
            Showing {visibleRows.length} rows
          </Typography>

          {/* Right Side: Fullscreen Control */}
          <Box sx={{ display: "flex", alignItems: "center", gap: 1 }}>
            {/* <Tooltip
              title={isFullscreen ? "Exit Full Screen (F)" : "Full Screen"}
              arrow
              placement="top"
            > */}
            <IconButton
              onClick={toggleFullscreen}
              size="small" // Ensures small icon size
              sx={{
                border: "1px solid",
                borderColor: "divider",
                mr: 0.5, // Small gap between button and text
              }}
            >
              {isFullscreen ? (
                <FullscreenExitIcon fontSize="small" />
              ) : (
                <FullscreenIcon fontSize="small" />
              )}
            </IconButton>
            {/* </Tooltip> */}

            {/* Text Label */}
            <Typography
              variant="caption"
              color="text.secondary"
              sx={{ userSelect: "none" }} // Prevents text highlighting on click
            >
              {isFullscreen ? "Exit Full Screen" : "Press F to Full Screen"}
            </Typography>
          </Box>
        </Box>
      </Paper>
    </Box>
  );
}






