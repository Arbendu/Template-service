import React, { useState, useEffect, useMemo } from "react";
import {
  Dialog,
  DialogTitle,
  DialogContent,
  DialogActions,
  Button,
  IconButton,
  FormControl,
  InputLabel,
  Select,
  MenuItem,
  TextField,
  Autocomplete,
  Box,
  Typography,
} from "@mui/material";
import CloseIcon from "@mui/icons-material/Close";

export default function FilterDialog({
  open,
  onClose,
  onApply,
  reportsConfig = [],
  currentFilters,
}) {
  // Local state for the dialog form
  const [reportCode, setReportCode] = useState("");
  const [head, setHead] = useState(null);
  const [scope, setScope] = useState("");
  const [entityCode, setEntityCode] = useState(""); // For specific Circle/Branch
  const [reportDate, setReportDate] = useState("");

  // Placeholder state for Autocomplete & Entity Dropdown options (To be connected to your APIs)
  const [headOptions, setHeadOptions] = useState([]);
  const [entityOptions, setEntityOptions] = useState([]);

  // Sync local state with currently applied filters when dialog opens
  useEffect(() => {
    if (open) {
      setReportCode(currentFilters?.reportCode || "");
      setHead(currentFilters?.head || null);
      setScope(currentFilters?.scope || "");
      setEntityCode(currentFilters?.entityCode || "");
      setReportDate(currentFilters?.reportDate || "");
    }
  }, [open, currentFilters]);

  const handleReset = () => {
    setReportCode("");
    setHead(null);
    setScope("");
    setEntityCode("");
    setReportDate("");
  };

  const handleApply = () => {
    onApply({
      reportCode,
      head,
      scope,
      entityCode: scope === "BANK" ? "" : entityCode,
      reportDate,
    });
    onClose();
  };

  // Validation: Check if all mandatory fields are filled
  const isApplyEnabled = useMemo(() => {
    const baseValid = reportCode && head && scope && reportDate;
    if (!baseValid) return false;
    if (scope === "CIRCLE" || scope === "BRANCH") {
      return !!entityCode;
    }
    return true; // BANK scope doesn't need entityCode
  }, [reportCode, head, scope, entityCode, reportDate]);

  return (
    <Dialog open={open} onClose={onClose} maxWidth="sm" fullWidth>
      <DialogTitle sx={{ display: "flex", justifyContent: "space-between", alignItems: "center" }}>
        <Typography variant="h6" fontWeight="bold">
          Report Filters
        </Typography>
        <IconButton onClick={onClose} size="small">
          <CloseIcon />
        </IconButton>
      </DialogTitle>

      <DialogContent dividers>
        <Box display="flex" flexDirection="column" gap={3} py={1}>
          
          {/* 1. Report Name */}
          <FormControl size="small" fullWidth>
            <InputLabel id="dialog-report-label">Database Report *</InputLabel>
            <Select
              labelId="dialog-report-label"
              value={reportCode}
              label="Database Report *"
              onChange={(e) => setReportCode(e.target.value)}
            >
              {reportsConfig.map((report) => (
                <MenuItem key={report.reportCode} value={report.reportCode}>
                  {report.displayName}
                </MenuItem>
              ))}
            </Select>
          </FormControl>

          {/* 2. Head / Head Code (Autocomplete) */}
          <Autocomplete
            size="small"
            options={headOptions}
            getOptionLabel={(option) => option?.name || ""}
            value={head}
            onChange={(event, newValue) => setHead(newValue)}
            onInputChange={(event, newInputValue) => {
              // TODO: Trigger your backend API search here based on newInputValue
              // setHeadOptions(response.data);
            }}
            renderInput={(params) => (
              <TextField {...params} label="Search Head / Head Code *" variant="outlined" />
            )}
          />

          {/* 3. Scope */}
          <FormControl size="small" fullWidth>
            <InputLabel id="dialog-scope-label">Scope *</InputLabel>
            <Select
              labelId="dialog-scope-label"
              value={scope}
              label="Scope *"
              onChange={(e) => {
                setScope(e.target.value);
                setEntityCode(""); // Reset entity when scope changes
              }}
            >
              <MenuItem value="BANK">BANK</MenuItem>
              <MenuItem value="CIRCLE">CIRCLE</MenuItem>
              <MenuItem value="BRANCH">BRANCH</MenuItem>
            </Select>
          </FormControl>

          {/* Conditional Dropdown for Circle/Branch */}
          {(scope === "CIRCLE" || scope === "BRANCH") && (
            <FormControl size="small" fullWidth>
              <InputLabel id="dialog-entity-label">
                Select {scope === "CIRCLE" ? "Circle" : "Branch"} *
              </InputLabel>
              <Select
                labelId="dialog-entity-label"
                value={entityCode}
                label={`Select ${scope === "CIRCLE" ? "Circle" : "Branch"} *`}
                onChange={(e) => setEntityCode(e.target.value)}
              >
                {/* TODO: Populate dynamically based on user Role/Scope API */}
                {entityOptions.map((entity) => (
                  <MenuItem key={entity.id} value={entity.id}>
                    {entity.name}
                  </MenuItem>
                ))}
              </Select>
            </FormControl>
          )}

          {/* 4. Date */}
          <TextField
            type="date"
            size="small"
            fullWidth
            label="Report Date *"
            InputLabelProps={{ shrink: true }}
            value={reportDate}
            onChange={(e) => setReportDate(e.target.value)}
          />
        </Box>
      </DialogContent>

      <DialogActions sx={{ p: 2, px: 3 }}>
        <Button onClick={handleReset} color="inherit" variant="outlined">
          Reset
        </Button>
        <Button
          onClick={handleApply}
          color="primary"
          variant="contained"
          disabled={!isApplyEnabled}
        >
          Apply
        </Button>
      </DialogActions>
    </Dialog>
  );
}










