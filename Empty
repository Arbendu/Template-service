        display: "flex",
        justifyContent: "space-between",
        flexDirection: "row",
        flexShrink: 0,
      }}
    >
      {/* Left Side: Title & Icon */}
      <Box display="flex" alignItems="center" gap={2}>
        <Box sx={{ backgroundColor: "primary.main", borderRadius: "10px", width: 44, height: 44, display: "flex", alignItems: "center", justifyContent: "center" }}>
          <AnalyticsIcon sx={{ color: "primary.contrastText", fontSize: 24 }} />
        </Box>
        <Box sx={{ overflow: "hidden" }}>
          <Typography variant="h6" sx={{ fontWeight: 700, color: "text.primary" }}>
            {activeReport?.displayName || "Financial Analytics"}
          </Typography>
          <Typography variant="caption" sx={{ color: "text.primary" }}>
            Dynamic Drill-Down Matrix
          </Typography>
        </Box>
      </Box>

      {/* Right Side: Controls */}
      <Box display="flex" alignItems="center" gap={2}>
        {/* CHANGED minWidth to 250 */}
        <FormControl size="small" sx={{ minWidth: 250, maxWidth: 350, bgcolor: "background.paper", borderRadius: 1 }}>
          <InputLabel id="report-source-label" shrink>Database Report</InputLabel>
          <Select
            labelId="report-source-label"
            value={selectedReportCode}
            label="Database Report"
            onChange={(e) => {
              setSelectedReportCode(e.target.value);
              setSelectedViewCode("");
            }}
            displayEmpty
            notched
          >
            <MenuItem value="" disabled><Typography sx={{ fontSize: "14px" }}>Please select a report</Typography></MenuItem>
            {reportsConfig.map((report) => (
              <MenuItem key={report.reportCode} value={report.reportCode}>
                <Typography sx={{ fontSize: "14px" }}>{report.displayName}</Typography>
              </MenuItem>
            ))}
          </Select>
        </FormControl>

        {/* CHANGED minWidth to 250 */}
        <FormControl size="small" sx={{ minWidth: 250, maxWidth: 350, bgcolor: "background.paper", borderRadius: 1 }}>
          <InputLabel id="hierarchy-view-label" shrink>Hierarchy View</InputLabel>
          <Select
            labelId="hierarchy-view-label"
            value={selectedViewCode}
            label="Hierarchy View"
            onChange={(e) => setSelectedViewCode(e.target.value)}
            displayEmpty
            notched
            disabled={!activeReport}
          >
            <MenuItem value="" disabled><Typography sx={{ fontSize: "14px" }}>Please select a view hierarchy</Typography></MenuItem>
            {activeReport?.views?.map((view) => (
              <MenuItem key={view.viewCode} value={view.viewCode}>
                <Typography sx={{ fontSize: "14px" }}>{view.displayName}</Typography>
              </MenuItem>
            ))}
          </Select>
        </FormControl>

        {/* ADDED Date Picker here */}
        <TextField
          type="date"
          size="small"
          label="Report Date"
          InputLabelProps={{ shrink: true }}
          value={selectedDate}
          onChange={(e) => setSelectedDate(e.target.value)}
          sx={{ bgcolor: "background.paper", minWidth: 160 }}
        />
      </Box>
    </Paper>
  );
}














