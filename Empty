export default function ReportAnalysisHeader({
  activeReport,
  reportsConfig,
  selectedReportCode,
  setSelectedReportCode,
  selectedViewCode,
  setSelectedViewCode,
  // ADD NEW PROPS for Date Picker
  selectedDate,
  setSelectedDate
}) {
  return (
    <Paper
      elevation={0}
      sx={{
        p: 3,
        borderRadius: 2,
        boxShadow: "0 5px 10px rgba(0,0,0,0.2)",
