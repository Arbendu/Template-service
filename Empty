export const fetchAnalyticsData = async (callApi, showSnackBar, payload) => {
  try {
    const responseData = await callApi("/AS/analytics/drill-down", payload, "POST");
    return responseData?.data || [];
  } catch (error) {
    console.error("Error fetching analytics data:", error);
    showSnackBar("Error: " + error.title, "error");
  }
};

// ADDED: reportDate parameter
export const fetchInitialData = async (callApi, showSnackBar, viewCode, hierarchy, metrics, reportDate) => {
  const rootDimension = hierarchy[0];
  const payload = {
    viewCode: viewCode,
    reportDate: reportDate, // <--- Added to payload
    dimensions: [rootDimension],
    metrics: metrics.map((m) => m.logicalName),
    filters: [],
  };
  
  const apiData = await fetchAnalyticsData(callApi, showSnackBar, payload);

  return (apiData || []).map((row) => ({
    ...row,
    level: 0,
    nodeFilters: [],
  }));
};

// ADDED: reportDate parameter
export const fetchChildrenData = async (callApi, showSnackBar, parentNode, viewCode, hierarchy, metrics, reportDate) => {
  const childLevel = parentNode.level + 1;
  const nextDimension = hierarchy[childLevel];

  const currentFilters = [
    ...(parentNode.nodeFilters || []),
    {
      logicalField: hierarchy[parentNode.level],
      operator: "EQUALS",
      value: parentNode.name,
    },
  ];

  const payload = {
    viewCode: viewCode,
    reportDate: reportDate, // <--- Added to payload
    dimensions: [nextDimension],
    metrics: metrics.map((m) => m.logicalName),
    filters: currentFilters,
  };
  
  const apiData = await fetchAnalyticsData(callApi, showSnackBar, payload);

  return (apiData || []).map((row) => ({
    ...row,
    level: childLevel,
    nodeFilters: currentFilters,
  }));
};













