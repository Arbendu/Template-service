import com.fasterxml.jackson.core.JsonParser;
import com.fasterxml.jackson.core.JsonToken;

// ... (Inside ReportTemplateConfigStrategy class)

private CommonReq mapToDto(CommonReq req) {
    CommonReq filteredReq = new CommonReq();
    filteredReq.setId(req.getId());
    filteredReq.setReqType(req.getReqType());
    filteredReq.setReqStatus(req.getReqStatus());
    filteredReq.setChangeType(req.getChangeType());
    filteredReq.setCreatorId(req.getCreatorId());
    filteredReq.setReqDate(req.getReqDate());
    filteredReq.setTargetId(req.getTargetId());

    Map<String, String> summary = new HashMap<>();
    // Fallback default
    summary.put("reportId", req.getTargetId());

    if (req.getPayload() != null && !req.getPayload().isBlank()) {
        try (JsonParser parser = objectMapper.getFactory().createParser(req.getPayload())) {
            while (!parser.isClosed()) {
                JsonToken token = parser.nextToken();
                if (token == null) break;

                if (JsonToken.FIELD_NAME.equals(token)) {
                    String fieldName = parser.getCurrentName();

                    if ("templateId".equals(fieldName)) {
                        parser.nextToken();
                        summary.put("templateId", parser.getValueAsString());
                    } else if ("version".equals(fieldName)) {
                        parser.nextToken();
                        summary.put("version", parser.getValueAsString());
                    } else if ("reportId".equals(fieldName)) {
                        parser.nextToken();
                        summary.put("reportId", parser.getValueAsString());
                    } else if ("reportName".equals(fieldName)) {
                        parser.nextToken();
                        summary.put("reportName", parser.getValueAsString());
                    } else if ("remarks".equals(fieldName)) {
                        parser.nextToken();
                        summary.put("remarks", parser.getValueAsString());
                    } 
                    // 🚀 THE MAGIC SAUCE: If we hit a massive array/object, skip it completely!
                    else if ("reportData".equals(fieldName) || "variants".equals(fieldName) || "globalParams".equals(fieldName)) {
                        parser.nextToken();    // Move pointer into the object/array
                        parser.skipChildren(); // INSTANTLY jumps over the entire block (0 memory used)
                    }
                }
            }
        } catch (Exception e) {
            log.error("Fast JSON streaming failed for request ID: " + req.getId(), e);
        }
    }

    try {
        filteredReq.setPayload(objectMapper.writeValueAsString(summary));
    } catch (JsonProcessingException e) {
        filteredReq.setPayload("{}");
    }
    
    return filteredReq;
}
