          ) : null}
        </TableContainer>

        <Box sx={{ bgcolor: "background.paper", borderTop: 1, borderColor: "divider", px: 2, py: 1, display: "flex", justifyContent: "space-between", alignItems: "center", minHeight: 40 }}>
          <Typography variant="caption" color="text.secondary" fontWeight={500}>
            Showing {visibleRows.length} rows
          </Typography>
          <Box sx={{ display: "flex", alignItems: "center", gap: 1 }}>
            <IconButton onClick={toggleFullscreen} size="small" sx={{ border: "1px solid", borderColor: "divider", mr: 0.5 }}>
              {isFullscreen ? <FullscreenExitIcon fontSize="small" /> : <FullscreenIcon fontSize="small" />}
            </IconButton>
            <Typography variant="caption" color="text.secondary" sx={{ userSelect: "none" }}>
              {isFullscreen ? "Exit Full Screen" : "Press F to Full Screen"}
            </Typography>
          </Box>
        </Box>
      </Paper>
    </Box>
  );
}
