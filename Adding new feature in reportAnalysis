import React, { useState, useEffect, useMemo } from "react";
import {
  Dialog,
  DialogTitle,
  DialogContent,
  DialogActions,
  Button,
  IconButton,
  FormControl,
  InputLabel,
  Select,
  MenuItem,
  TextField,
  Autocomplete,
  Box,
  Typography,
  FormHelperText,
  CircularProgress,
} from "@mui/material";
import CloseIcon from "@mui/icons-material/Close";
import InfoIcon from "@mui/icons-material/Info";
import QueryStatsIcon from "@mui/icons-material/QueryStats";
import { fetchHeads, fetchEntities } from "../api/analyticsApi";

export default function FilterDialog({
  open,
  onClose,
  onApply,
  reportsConfig = [],
  currentFilters,
  callApi, // Passed down to execute dynamic API calls internally
}) {
  const [reportCode, setReportCode] = useState("");
  const [head, setHead] = useState(null);
  const [scope, setScope] = useState("");
  const [entityCode, setEntityCode] = useState("");
  const [reportDate, setReportDate] = useState("");

  const [headInputValue, setHeadInputValue] = useState("");
  const [headOptions, setHeadOptions] = useState([]);
  const [isHeadsLoading, setIsHeadsLoading] = useState(false);

  const [entityOptions, setEntityOptions] = useState([]);
  const [isEntitiesLoading, setIsEntitiesLoading] = useState(false);

  // Sync state when dialog opens
  useEffect(() => {
    if (open) {
      setReportCode(currentFilters?.reportCode || "");
      setHead(currentFilters?.head || null);
      setScope(currentFilters?.scope || "");
      setEntityCode(currentFilters?.entityCode || "");
      setReportDate(currentFilters?.reportDate || "");
      
      // Seed autocomplete options if head is already selected
      if (currentFilters?.head) setHeadOptions([currentFilters.head]);
    }
  }, [open, currentFilters]);

  // Dynamically derive available Scopes from the selected Report's config views (e.g., parsing "PNL_BANK" -> "BANK")
  const availableScopes = useMemo(() => {
    if (!reportCode) return [];
    const report = reportsConfig.find((r) => r.reportCode === reportCode);
    if (!report?.views) return [];
    return report.views.map((v) => v.viewCode.split("_")[1]);
  }, [reportCode, reportsConfig]);

  // Debounced API call for Head Code Autocomplete
  useEffect(() => {
    const delayDebounceFn = setTimeout(async () => {
      if (headInputValue && headInputValue.length >= 2 && reportCode) {
        setIsHeadsLoading(true);
        const data = await fetchHeads(callApi, reportCode, headInputValue);
        setHeadOptions(data);
        setIsHeadsLoading(false);
      } else {
        setHeadOptions(head ? [head] : []);
      }
    }, 500);

    return () => clearTimeout(delayDebounceFn);
  }, [headInputValue, reportCode, callApi, head]);

  // Dynamic API call for Entity List (Circle / Branch) based on Scope selection
  useEffect(() => {
    const loadEntities = async () => {
      if (scope === "CIRCLE" || scope === "BRANCH") {
        setIsEntitiesLoading(true);
        const data = await fetchEntities(callApi, scope);
        setEntityOptions(data);
        setIsEntitiesLoading(false);
      } else {
        setEntityOptions([]);
      }
    };
    loadEntities();
  }, [scope, callApi]);

  const handleReset = () => {
    setReportCode("");
    setHead(null);
    setScope("");
    setEntityCode("");
    setReportDate("");
    setHeadOptions([]);
  };

  const handleApply = () => {
    onApply({
      reportCode,
      head,
      scope,
      entityCode: scope === "BANK" ? "" : entityCode,
      reportDate,
    });
    onClose();
  };

  const isApplyEnabled = useMemo(() => {
    const baseValid = reportCode && head?.headCode && scope && reportDate;
    if (!baseValid) return false;
    if (scope === "CIRCLE" || scope === "BRANCH") return !!entityCode;
    return true;
  }, [reportCode, head, scope, entityCode, reportDate]);

  return (
    <Dialog open={open} onClose={onClose} maxWidth="sm" fullWidth>
      <DialogTitle sx={{ display: "flex", justifyContent: "space-between", alignItems: "center", gap: 2 }}>
        <Typography variant="h6" fontWeight="bold" sx={{ display: "flex", alignItems: "center", gap: 2 }}>
          <QueryStatsIcon /> Drill Down Filters
        </Typography>
        <IconButton onClick={onClose} size="small">
          <CloseIcon />
        </IconButton>
      </DialogTitle>

      <DialogContent dividers>
        <Box display="flex" flexDirection="column" gap={3} py={1}>
          
          <FormControl size="small" fullWidth>
            <InputLabel id="dialog-report-label">Select Report *</InputLabel>
            <Select
              labelId="dialog-report-label"
              value={reportCode}
              label="Select Report *"
              onChange={(e) => {
                setReportCode(e.target.value);
                setScope("");
                setEntityCode("");
              }}
            >
              {reportsConfig.map((report) => (
                <MenuItem key={report.reportCode} value={report.reportCode}>
                  {report.displayName}
                </MenuItem>
              ))}
            </Select>
          </FormControl>

          <Autocomplete
            size="small"
            options={headOptions}
            getOptionLabel={(option) => option ? `${option.headCode} - ${option.headName}` : ""}
            value={head}
            onChange={(event, newValue) => setHead(newValue)}
            onInputChange={(event, newInputValue) => setHeadInputValue(newInputValue)}
            loading={isHeadsLoading}
            disabled={!reportCode}
            renderInput={(params) => (
              <TextField
                {...params}
                label="Search Head Code *"
                variant="outlined"
                InputProps={{
                  ...params.InputProps,
                  endAdornment: (
                    <React.Fragment>
                      {isHeadsLoading ? <CircularProgress color="inherit" size={20} /> : null}
                      {params.InputProps.endAdornment}
                    </React.Fragment>
                  ),
                }}
                helperText={
                  <span style={{ display: "flex", alignItems: "center", gap: "4px" }}>
                    <InfoIcon sx={{ fontSize: "0.625rem" }} />
                    <em>Type 2+ characters to search head. Requires selected report.</em>
                  </span>
                }
              />
            )}
          />

          <FormControl size="small" fullWidth disabled={!reportCode}>
            <InputLabel id="dialog-scope-label">Scope *</InputLabel>
            <Select
              labelId="dialog-scope-label"
              value={scope}
              label="Scope *"
              onChange={(e) => {
                setScope(e.target.value);
                setEntityCode("");
              }}
            >
              {availableScopes.map((availableScope) => (
                <MenuItem key={availableScope} value={availableScope}>
                  {availableScope}
                </MenuItem>
              ))}
            </Select>
          </FormControl>

          {(scope === "CIRCLE" || scope === "BRANCH") && (
            <FormControl size="small" fullWidth>
              <InputLabel id="dialog-entity-label">Select {scope === "CIRCLE" ? "Circle" : "Branch"} *</InputLabel>
              <Select
                labelId="dialog-entity-label"
                value={entityCode}
                label={`Select ${scope === "CIRCLE" ? "Circle" : "Branch"} *`}
                onChange={(e) => setEntityCode(e.target.value)}
                disabled={isEntitiesLoading}
              >
                {isEntitiesLoading ? (
                   <MenuItem disabled value="">Loading entities...</MenuItem>
                ) : (
                  entityOptions.map((entity) => (
                    <MenuItem key={entity.id || entity.code} value={entity.id || entity.code}>
                      {entity.name}
                    </MenuItem>
                  ))
                )}
              </Select>
            </FormControl>
          )}

          <TextField
            type="date"
            size="small"
            fullWidth
            label="Report Date *"
            InputLabelProps={{ shrink: true }}
            value={reportDate}
            onChange={(e) => setReportDate(e.target.value)}
          />
        </Box>
      </DialogContent>

      <DialogActions sx={{ p: 2, px: 3 }}>
        <Button onClick={handleReset} color="inherit" variant="outlined">
          Reset
        </Button>
        <Button onClick={handleApply} color="primary" variant="contained" disabled={!isApplyEnabled}>
          Apply
        </Button>
      </DialogActions>
    </Dialog>
  );
}














