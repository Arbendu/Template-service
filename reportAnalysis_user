// ************************** api/analyticsApi.js ***************************** //


export const fetchAnalyticsData = async (callApi, showSnackBar, payload) => {
  try {
    const responseData = await callApi(
      "/AS/analytics/drill-down",
      payload,
      "POST",
    );
    console.log("Drill-down payload: ", payload);
    
    return responseData?.data || [];
  } catch (error) {
    console.error("Error fetching analytics data:", error);
    showSnackBar("Error: " + error.title, "error");
  }
};

export const fetchInitialData = async (
  callApi,
  showSnackBar,
  viewCode,
  hierarchy,
  metrics,
  reportDate
) => {
  const rootDimension = hierarchy[0];
  const payload = {
    viewCode: viewCode,
    reportDate: reportDate,
    dimensions: [rootDimension],
    metrics: metrics.map((m) => m.logicalName),
    filters: [],
  };
  const apiData = await fetchAnalyticsData(callApi, showSnackBar, payload);

  return (apiData || []).map((row) => ({
    ...row,
    level: 0,
    nodeFilters: [],
  }));
};

export const fetchChildrenData = async (
  callApi,
  showSnackBar,
  parentNode,
  viewCode,
  hierarchy,
  metrics,
  reportDate
) => {
  const childLevel = parentNode.level + 1;
  const nextDimension = hierarchy[childLevel];

  const currentFilters = [
    ...(parentNode.nodeFilters || []),
    {
      logicalField: hierarchy[parentNode.level],
      operator: "EQUALS",
      value: parentNode.name,
    },
  ];

  const payload = {
    viewCode: viewCode,
    reportDate: reportDate,
    dimensions: [nextDimension],
    metrics: metrics.map((m) => m.logicalName),
    filters: currentFilters,
  };
  const apiData = await fetchAnalyticsData(callApi, showSnackBar, payload);

  return (apiData || []).map((row) => ({
    ...row,
    level: childLevel,
    nodeFilters: currentFilters,
  }));
};










// ************************ components/ActualTreeTableRow.jsx **************************** //


import React, { memo, forwardRef } from "react";
import { TableRow, TableCell, CircularProgress } from "@mui/material";
import { formatCurrency } from "../utils/analyticsConstants";
import ContentCopyIcon from "@mui/icons-material/ContentCopy";
import { IconButton, Tooltip } from "@mui/material";

const ActualTreeTableRow = memo(
  forwardRef(
    (
      {
        node,
        isExpanded,
        isLoading,
        onToggle,
        maxVisibleLevel,
        index,
        activeMetrics,
        theme,
        isFullscreen,
        showSnackBar,
        ...props
      },
      ref,
    ) => {
      const isRoot = node.level === 0;

      return (
        <TableRow
          ref={ref}
          hover
          style={{
            backgroundColor: isExpanded
              ? theme.palette.purple?.[100] || "inherit"
              : "inherit",
            borderLeft: isExpanded
              ? `4px solid ${theme.palette.primary.main}`
              : "4px solid transparent",
            height: "40px",
            transition:
              "background-color 0.2s ease-in-out, border-color 0.2s ease-in-out",
          }}
          {...props}
        >
          {Array.from({ length: maxVisibleLevel + 1 }).map((_, colIndex) => {
            if (colIndex === node.level) {
              return (
                <TableCell
                  key={colIndex}
                  style={{
                    borderRight: `1px solid ${theme.palette.divider}`,
                    borderBottom: `1px solid ${theme.palette.divider}`,
                    //minWidth: "260px",
                    whiteSpace: "nowrap",
                    padding: "4px 4px",
                    verticalAlign: "middle",
                  }}
                >
                  <div
                    style={{
                      display: "flex",
                      alignItems: "center",
                      paddingLeft: `${node.level * 10 + 8}px`,
                      paddingRight: "16px",
                      width: "100%",
                      boxSizing: "border-box",
                    }}
                  >
                    {node.hasChildren ? (
                      <button
                        onClick={(e) => {
                          e.stopPropagation();
                          onToggle(node);
                        }}
                        disabled={isLoading}
                        style={{
                          marginRight: "8px",
                          padding: 0,
                          width: "20px",
                          height: "20px",
                          border: `1px solid ${isExpanded ? theme.palette.primary.main : theme.palette.divider}`,
                          borderRadius: "50%",
                          backgroundColor: "transparent",
                          cursor: isLoading ? "wait" : "pointer",
                          display: "flex",
                          alignItems: "center",
                          justifyContent: "center",
                          color: isExpanded
                            ? theme.palette.primary.main
                            : "inherit",
                          fontSize: "14px",
                          lineHeight: 1,
                          transition: "all 0.15s ease",
                        }}
                        onMouseOver={(e) =>
                          (e.currentTarget.style.transform = "scale(1.15)")
                        }
                        onMouseOut={(e) =>
                          (e.currentTarget.style.transform = "scale(1)")
                        }
                      >
                        {isLoading ? (
                          <CircularProgress
                            size={12}
                            color={isExpanded ? "primary.dark" : "inherit"}
                          />
                        ) : isExpanded ? (
                          "-"
                        ) : (
                          "+"
                        )}
                      </button>
                    ) : (
                      <div style={{ width: "28px" }} />
                    )}
                    <span
                      style={{
                        fontWeight: isExpanded ? 700 : isRoot ? 600 : 400,
                        color: isExpanded
                          ? theme.palette.primary.main
                          : "inherit",
                        whiteSpace: "nowrap",
                        overflow: "hidden",
                        textOverflow: "ellipsis",
                        fontSize: "0.875rem",
                        fontFamily:
                          theme.typography.fontFamily ||
                          "Roboto, Helvetica, Arial, sans-serif",
                      }}
                    >
                      {node.name}
                    </span>

                    {/* Checks if it's fullscreen, expanded, data is loaded, and targets HeadCode (level 1) */}
                    {isFullscreen &&
                      isExpanded &&
                      !isLoading &&
                      node.level === 1 &&
                      node.children && (
                        <Tooltip title="Copy all GLCODEs" placement="top" arrow>
                          <IconButton
                            size="small"
                            onClick={(e) => {
                              e.stopPropagation(); // Prevents row toggle when clicking the copy button

                              // 1. Format the parent (Headcode) row
                              // We use node.name and node.TotalAmount for the parent
                              const headcodeRow = `${node.name}\t${node.TotalAmount || ""}`;

                              // 2. Format the children (GLCODEs) rows
                              const childrenRows = node.children
                                .map(
                                  (child) =>
                                    `${child.name}\t${child.TotalAmount || ""}`,
                                )
                                .join("\n");

                              // 3. Combine them with a newline (\n) in between
                              const combinedData = `${headcodeRow}\n${childrenRows}`;

                              console.log("Copied Data:\n", combinedData);

                              // 4. Send the whole block to the clipboard
                              navigator.clipboard
                                .writeText(combinedData)
                                .then(() => {
                                  showSnackBar(
                                    "Text copied successfully",
                                    "success",
                                  );
                                })
                                .catch((err) => {
                                  console.error("Failed to copy text: ", err);
                                  showSnackBar("Failed to copy text", "error");
                                });
                            }}
                            sx={{ ml: 2, padding: "2px" }}
                          >
                            <ContentCopyIcon
                              sx={{ fontSize: 16, color: "text.secondary" }}
                            />
                          </IconButton>
                        </Tooltip>
                      )}
                  </div>
                </TableCell>
              );
            }
            return (
              <TableCell
                key={colIndex}
                style={{
                  borderRight: `1px solid ${theme.palette.divider}`,
                  borderBottom: `1px solid ${theme.palette.divider}`,
                  whiteSpace: "nowrap",
                  padding: 0,
                }}
              />
            );
          })}

          {activeMetrics.map((metric) => {
            const value = node[metric.logicalName];
            return (
              <TableCell
                key={metric.logicalName}
                align="right"
                style={{
                  borderRight: `1px solid ${theme.palette.divider}`,
                  borderBottom: `1px solid ${theme.palette.divider}`,
                  // width: "160px",
                  // minWidth: "160px",
                  // maxWidth: "160px",
                  //padding: "8px 16px",
                  color:
                    value < 0
                      ? theme.palette.error.main
                      : theme.palette.success.main,
                  fontWeight: 500,
                  whiteSpace: "nowrap",
                  verticalAlign: "middle",
                  fontSize: "0.875rem",
                  fontFamily:
                    theme.typography.fontFamily ||
                    "Roboto, Helvetica, Arial, sans-serif",
                }}
              >
                {formatCurrency(value)}
              </TableCell>
            );
          })}
        </TableRow>
      );
    },
  ),
  (prevProps, nextProps) => {
    return (
      prevProps.isExpanded === nextProps.isExpanded &&
      prevProps.isLoading === nextProps.isLoading &&
      prevProps.node.id === nextProps.node.id &&
      prevProps.maxVisibleLevel === nextProps.maxVisibleLevel &&
      prevProps.index === nextProps.index &&
      prevProps.theme === nextProps.theme &&
      prevProps.isFullscreen === nextProps.isFullscreen
    );
  },
);

ActualTreeTableRow.displayName = "ActualTreeTableRow";
export default ActualTreeTableRow;










// *************************** components/HierarchyPath.jsx ******************************** //

import React from "react";
import { Box, Typography } from "@mui/material";
import { useTheme } from "@mui/material/styles";

export default function HierarchyPath({
  activeHierarchyConfig,
  maxVisibleLevel,
  isSetupComplete,
}) {
  const theme = useTheme();
  if (!isSetupComplete) return null;

  return (
    <Box display="flex" alignItems="center" gap={0.5}>
      <Typography
        variant="body2"
        color="text.secondary"
        sx={{ mr: 1, fontWeight: 500 }}
      >
        Path:
      </Typography>
      {activeHierarchyConfig.hierarchy.map((item, index) => {
        const isActive = index <= maxVisibleLevel;
        return (
          <Box key={index} display="flex" alignItems="center">
            <Box display="flex" alignItems="center" gap={1}>
              <Box
                sx={{
                  width: 10,
                  height: 10,
                  borderRadius: "50%",
                  bgcolor: isActive ? "primary.main" : "background.paper",
                  border: "2px solid",
                  borderColor: isActive ? "primary.main" : "divider",
                }}
              />
              <Typography
                variant="body2"
                sx={{
                  fontWeight: isActive ? 600 : 500,
                  color: isActive ? "text.primary" : "text.disabled",
                  textTransform: "capitalize",
                }}
              >
                {item.replace("_", " ")}
              </Typography>
            </Box>
            {index < activeHierarchyConfig.hierarchy.length - 1 && (
              <Box
                sx={{
                  backgroundColor:
                    index < maxVisibleLevel
                      ? theme.palette.primary.main
                      : theme.palette.divider,
                  width: 24,
                  height: 2,
                  mx: 1,
                  borderRadius: 1,
                }}
              />
            )}
          </Box>
        );
      })}
    </Box>
  );
}










