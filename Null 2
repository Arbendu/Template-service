export default function ReportAnalysisScreen() {
  const { callApi } = useApi();
  const dispatch = useDispatch();
  const user = useSelector((state) => state.auth.user);
  
  // Safe extraction of cache (assumes you registered it in root reducer as "analyticsCache")
  const cachedNodes = useSelector((state) => state.analyticsCache?.nodes || {});
  
  const showSnackBar = useCustomSnackbar();

  const [reportsConfig, setReportsConfig] = useState([]);
  const [selectedReportCode, setSelectedReportCode] = useState("");
  const [selectedViewCode, setSelectedViewCode] = useState("");

  const [data, setData] = useState([]);
  const [expandedIds, setExpandedIds] = useState(new Map());
  const [loadingIds, setLoadingIds] = useState(new Set());
  const [isInitializing, setIsInitializing] = useState(false);
  const [page, setPage] = useState(0);
  const [rowsPerPage, setRowsPerPage] = useState(25);

  const theme = useTheme();

  const activeReport = useMemo(() => {
    return (
      reportsConfig.find((r) => r.reportCode === selectedReportCode) || null
    );
  }, [reportsConfig, selectedReportCode]);

  const activeView = useMemo(() => {
    return (
      activeReport?.views?.find((v) => v.viewCode === selectedViewCode) || null
    );
  }, [activeReport, selectedViewCode]);

  const activeHierarchyConfig = activeView || DEFAULT_CONFIG;

  useEffect(() => {
    const fetchConfig = async () => {
      try {
        const response = await callApi("/AS/analytics/config", {}, "GET");
        const configData = Array.isArray(response)
          ? response
          : response?.data || [];
        setReportsConfig(configData);
      } catch (error) {
        console.error("Failed to fetch analytics configurations", error);
        showSnackBar("Failed to fetch analytics configurations", "error");
      }
    };
    if (user) fetchConfig();
  }, [callApi, user, showSnackBar]);

  useEffect(() => {
    setPage(0);
  }, [selectedReportCode, selectedViewCode]);

  useEffect(() => {
    const loadRoot = async () => {
      if (!selectedReportCode || !selectedViewCode) {
        setData((prev) => (prev.length === 0 ? prev : []));
        return;
      }
      setIsInitializing(true);
      setData([]);
      setExpandedIds(new Map());

      try {
        const rootData = await fetchInitialData(
          callApi,
          showSnackBar,
          selectedViewCode,
          activeHierarchyConfig.hierarchy,
          activeHierarchyConfig.availableMetrics,
        );
        setData(rootData);
      } catch (error) {
        console.error("Failed to load initial data", error);
      } finally {
        setIsInitializing(false);
      }
    };
    loadRoot();
  }, [
    selectedReportCode,
    selectedViewCode,
    activeHierarchyConfig,
    callApi,
    showSnackBar,
  ]);

  const appendChildrenToTree = useCallback((nodes, parentId, newChildren) => {
    return nodes.map((node) => {
      if (node.id === parentId) return { ...node, children: newChildren };
      if (node.children)
        return {
          ...node,
          children: appendChildrenToTree(node.children, parentId, newChildren),
        };
      return node;
    });
  }, []);

  const handleToggle = useCallback(
    async (node) => {
      const isExpanded = expandedIds.has(node.id);

      if (isExpanded) {
        // Manual Collapse
        setExpandedIds((prev) => {
          const next = new Map(prev);
          next.delete(node.id);

          const removeDescendants = (currentNode) => {
            if (currentNode.children) {
              currentNode.children.forEach((child) => {
                next.delete(child.id);
                removeDescendants(child);
              });
            }
          };
          removeDescendants(node);
          return next;
        });
      } else {
        // Expansion (Auto-Collapse Sibling Mode)
        if (!node.children && node.hasChildren) {
          
          // --- REDUX CACHE LOGIC START ---
          const cacheKey = `${selectedViewCode}_${node.id}`;
          const cachedEntry = cachedNodes[cacheKey];
          // 15 minutes TTL check (15 * 60 * 1000 = 900000 ms)
          const isCacheValid = cachedEntry && (Date.now() - cachedEntry.timestamp < 900000);

          if (isCacheValid) {
            // CACHE HIT: Instantly load data from Redux
            setData((prevData) =>
              appendChildrenToTree(prevData, node.id, cachedEntry.data)
            );
          } else {
            // CACHE MISS: Fetch from API
            setLoadingIds((prev) => new Set(prev).add(node.id));
            try {
              const children = await fetchChildrenData(
                callApi,
                showSnackBar,
                node,
                selectedViewCode,
                activeHierarchyConfig.hierarchy,
                activeHierarchyConfig.availableMetrics,
              );
              
              setData((prevData) =>
                appendChildrenToTree(prevData, node.id, children),
              );

              // Dispatch the new data to Redux cache
              dispatch({
                type: "analyticsCache/cacheNode", 
                payload: { key: cacheKey, data: children, timestamp: Date.now() }
              });

            } catch (error) {
              console.error("Failed to fetch children", error);
            } finally {
              setLoadingIds((prev) => {
                const next = new Set(prev);
                next.delete(node.id);
                return next;
              });
            }
          }
          // --- REDUX CACHE LOGIC END ---
        }
        
        // ACCORDION LOGIC
        setExpandedIds((prev) => {
          const next = new Map();
          // Loop through all currently expanded nodes
          prev.forEach((level, id) => {
            // Keep the node ONLY if it is at a higher depth level (meaning it's a direct ancestor)
            if (level < node.level) {
              next.set(id, level);
            }
          });
          // Add the newly clicked node
          next.set(node.id, node.level);
          return next;
        });
      }
    },
    [
      expandedIds,
      appendChildrenToTree,
      activeHierarchyConfig.hierarchy,
      activeHierarchyConfig.availableMetrics,
      selectedViewCode,
      callApi,
      showSnackBar,
      cachedNodes,
      dispatch
    ],
  );

  const visibleRows = useMemo(() => {
    const rows = [];
    const traverse = (nodes) => {
      for (const node of nodes) {
        rows.push(node);
        if (expandedIds.has(node.id) && node.children) traverse(node.children);
      }
    };
    traverse(data);
    return rows;
  }, [data, expandedIds]);

  // PAGINATION SAFETY NET
  useEffect(() => {
    const maxPage = Math.max(0, Math.ceil(visibleRows.length / rowsPerPage) - 1);
    if (page > maxPage) {
      setPage(maxPage);
    }
  }, [visibleRows.length, rowsPerPage, page]);

  const maxVisibleLevel = useMemo(() => {
    if (visibleRows.length === 0) return 0;
    return Math.max(...visibleRows.map((row) => row.level));
  }, [visibleRows]);

  const visibleHierarchyLevels = activeHierarchyConfig.hierarchy.slice(
    0,
    maxVisibleLevel + 1,
  );

  const paginatedRows = useMemo(() => {
    const startIndex = page * rowsPerPage;
    return visibleRows.slice(startIndex, startIndex + rowsPerPage);
  }, [visibleRows, page, rowsPerPage]);

  const handleChangePage = (event, newPage) => setPage(newPage);
  const handleChangeRowsPerPage = (event) => {
    setRowsPerPage(parseInt(event.target.value, 10));
    setPage(0);
  };

  const isSetupComplete = selectedReportCode && selectedViewCode;

  const pathContainerVariants = {
    hidden: { opacity: 0 },
    show: {
      opacity: 1,
      transition: { staggerChildren: 0.05 },
    },
    exit: { opacity: 0, transition: { duration: 0.1 } },
  };

  const pathChipVariants = {
    hidden: { opacity: 0, x: -20 },
    show: {
      opacity: 1,
      x: 0,
      transition: { type: "spring", stiffness: 350, damping: 25 },
    },
  };

  return (
    <Box
      sx={{
        height: "calc(100vh - 220px)",
        display: "flex",
        flexDirection: "column",
        gap: 1.5,
      }}
    >
      {/* ================= UPPER BOX ================= */}
      <Paper
        elevation={0}
        sx={{
          p: 3,
          borderRadius: 2,
          boxShadow: "0 5px 10px rgba(0,0,0,0.2)",
          border: 1,
          borderColor: "divider",
          display: "flex",
          justifyContent: 'space-between',
          flexDirection: "row",
        }}
      >
        <Box display="flex" alignItems="center" gap={2}>
          <MotionBox
            initial={{ scale: 0, rotate: -180 }}
            animate={{ scale: 1, rotate: 0 }}
            transition={{ type: "spring", stiffness: 260, damping: 20 }}
            sx={{
              backgroundColor: "primary.main",
              borderRadius: "10px",
              width: 44,
              height: 44,
              display: "flex",
              alignItems: "center",
              justifyContent: "center",
            }}
          >
            <AnalyticsIcon
              sx={{ color: "primary.contrastText", fontSize: 24 }}
            />
          </MotionBox>

          <Box sx={{ overflow: "hidden" }}>
            <AnimatePresence mode="wait">
              <MotionBox
                key={activeReport?.displayName || "Analytics"}
                initial={{ opacity: 0, x: -30 }}
                animate={{ opacity: 1, x: 0 }}
                exit={{ opacity: 0, x: 30 }}
                transition={{ duration: 0.3 }}
              >
                <Typography
                  variant="h6"
                  sx={{ fontWeight: 700, color: "text.primary" }}
                >
                  {activeReport?.displayName || "Financial Analytics"}
                </Typography>
              </MotionBox>
            </AnimatePresence>
            <Typography
              variant="caption"
              sx={{ color: "text.primary", }}
            >
              Dynamic Drill-Down Matrix
            </Typography>
          </Box>
        </Box>

        <Box display="flex" alignItems="center" gap={2}>
          <FormControl
            size="small"
            sx={{
              minWidth: 400,
              maxWidth: 500,
              bgcolor: "background.paper",
              borderRadius: 1,
              "& .MuiOutlinedInput-root.Mui-focused fieldset": {
                boxShadow: `0 0 8px ${theme.palette.primary.light}`,
              },
            }}
          >
            <InputLabel id="report-source-label" shrink>
              Database Report
            </InputLabel>
            <Select
              labelId="report-source-label"
              value={selectedReportCode}
              label="Database Report"
              onChange={(e) => {
                setSelectedReportCode(e.target.value);
                setSelectedViewCode("");
              }}
              displayEmpty
              notched
            >
              <MenuItem value="" disabled >
                <Typography sx={{fontSize: '14px'}}> Please select a report</Typography>
              </MenuItem>
              {reportsConfig.map((report) => (
                <MenuItem key={report.reportCode} value={report.reportCode}>
                  <Typography sx={{fontSize: '14px'}}>{report.displayName}</Typography>
                </MenuItem>
              ))}
            </Select>
          </FormControl>

          <FormControl
            size="small"
            sx={{
              minWidth: 300,
              maxWidth: 350,
              bgcolor: "background.paper",
              borderRadius: 1,
              "& .MuiOutlinedInput-root.Mui-focused fieldset": {
                boxShadow: `0 0 8px ${theme.palette.primary.light}`,
              },
            }}
          >
            <InputLabel id="hierarchy-view-label" shrink>
              Hierarchy View
            </InputLabel>
            <Select
              labelId="hierarchy-view-label"
              value={selectedViewCode}
              label="Hierarchy View"
              onChange={(e) => setSelectedViewCode(e.target.value)}
              displayEmpty
              notched
              disabled={!activeReport}
            >
              <MenuItem value="" disabled>
                <Typography sx={{fontSize: '14px'}}>Please select a view hierarchy</Typography>
              </MenuItem>
              {activeReport?.views?.map((view) => (
                <MenuItem key={view.viewCode} value={view.viewCode}>
                  <Typography sx={{fontSize: '14px'}}>{view.displayName}</Typography>
                </MenuItem>
              ))}
            </Select>
          </FormControl>
        </Box>
      </Paper>

      {/* ================= LOWER BOX ================= */}
      <Paper
        elevation={0}
        sx={{
          flexGrow: 1,
          display: "flex",
          flexDirection: "column",
          overflow: "hidden",
          borderRadius: 1,
          boxShadow: "0 2px 10px rgba(0,0,0,0.03)",
          border: 1,
          borderColor: "divider",
        }}
      >
        <Box
          sx={{
            borderBottom: 1,
            borderColor: "divider",
            px: 2,
            py: 2,
            minHeight: 44,
            display: "flex",
            alignItems: "center",
          }}
        >
          {isSetupComplete && (
            <MotionBox
              variants={pathContainerVariants}
              initial="hidden"
              animate="show"
              exit="hidden"
              display="flex"
              alignItems="center"
              gap={0.5}
            >
              <Typography
                variant="body2"
                color="text.secondary"
                sx={{ mr: 1, fontWeight: 500 }}
              >
                Path:
              </Typography>
              {activeHierarchyConfig.hierarchy.map((item, index) => {
                const isActive = index <= maxVisibleLevel;
                const isCurrent = index === maxVisibleLevel;
                return (
                  <Box key={index} display="flex" alignItems="center">
                    <MotionBox
                      variants={pathChipVariants}
                      display="flex"
                      alignItems="center"
                      gap={1}
                    >
                      <MotionBox
                        animate={
                          isActive
                            ? isCurrent
                              ? {
                                  scale: [1, 1.2, 1],
                                  boxShadow: `0px 0px 8px ${theme.palette.primary.main}`,
                                }
                              : { scale: 1, boxShadow: "none" }
                            : { scale: 0.8, boxShadow: "none" }
                        }
                        transition={
                          isCurrent
                            ? {
                                repeat: Infinity,
                                duration: 1.5,
                                ease: "easeInOut",
                              }
                            : { duration: 0.2 }
                        }
                        sx={{
                          width: 10,
                          height: 10,
                          borderRadius: "50%",
                          bgcolor: isActive
                            ? "primary.main"
                            : "background.paper",
                          border: "2px solid",
                          borderColor: isActive ? "primary.main" : "divider",
                        }}
                      />
                      <Typography
                        variant="body2"
                        sx={{
                          fontWeight: isActive ? 600 : 500,
                          color: isActive ? "text.primary" : "text.disabled",
                          textTransform: "capitalize",
                        }}
                      >
                        {item.replace("_", " ")}
                      </Typography>
                    </MotionBox>

                    {index < activeHierarchyConfig.hierarchy.length - 1 && (
                      <MotionBox
                        variants={pathChipVariants}
                        animate={{
                          backgroundColor:
                            index < maxVisibleLevel
                              ? theme.palette.primary.main
                              : theme.palette.divider,
                        }}
                        sx={{ width: 24, height: 2, mx: 1, borderRadius: 1 }}
                      />
                    )}
                  </Box>
                );
              })}
            </MotionBox>
          )}
        </Box>

        <TableContainer
          sx={{
            flexGrow: 1,
            bgcolor: "background.default",
            position: "relative",
          }}
        >
          {!isSetupComplete && (
            <Box
              sx={{
                position: "absolute",
                top: 0,
                left: 0,
                right: 0,
                bottom: 0,
                display: "flex",
                flexDirection: "column",
                alignItems: "center",
                justifyContent: "center",
                zIndex: 10,
              }}
            >
              <MotionBox
                animate={{ y: [0, -15, 0] }}
                transition={{
                  repeat: Infinity,
                  duration: 2.5,
                  ease: "easeInOut",
                }}
              >
                <DatasetIcon
                   sx={{ fontSize: 64, color: "action.disabled", mb: 1 }}
                />
              </MotionBox>
              <Typography variant="h6" color="text.secondary">
                No Data to Display
              </Typography>
              <Typography variant="body2" color="text.disabled">
                Please select both a database report and a hierarchy view above.
              </Typography>
            </Box>
          )}

          {isInitializing ? (
            <Box
              sx={{
                height: "100%",
                display: "flex",
                flexDirection: "column",
                alignItems: "center",
                justifyContent: "center",
              }}
            >
              <CircularProgress size={32} color="primary" sx={{ mb: 1 }} />
              <Typography variant="body2" color="text.secondary">
                Executing Query ...
              </Typography>
            </Box>
          ) : isSetupComplete ? (
            <Table
              stickyHeader
              size="small"
              sx={{ minWidth: 1000, tableLayout: "auto" }}
            >
              <TableHead>
                <TableRow>
                  {visibleHierarchyLevels.map((levelName, index) => (
                    <TableCell
                      key={levelName}
                      sx={{
                        backgroundColor: theme.palette.purple[100],
                        color: "text.primary",
                        fontWeight: 700,
                        borderRight: 1,
                        borderColor: "divider",
                        borderBottom: 2,
                        py: 1,
                        width: index === 0 ? 280 : "auto",
                      }}
                    >
                      {levelName.replace("_", " ").toUpperCase()}
                    </TableCell>
                  ))}
                  {activeHierarchyConfig.availableMetrics.map((metric) => (
                    <TableCell
                      key={metric.logicalName}
                      align="right"
                      sx={{
                        backgroundColor: theme.palette.purple
                          ? theme.palette.purple[200]
                          : "#eeeeee",
                        color: "text.primary",
                        fontWeight: 700,
                        borderRight: 1,
                        borderColor: "divider",
                        borderBottom: 2,
                        py: 1,
                      }}
                    >
                      {metric.displayName}
                    </TableCell>
                  ))}
                </TableRow>
              </TableHead>
              <TableBody>
                <AnimatePresence initial={false}>
                  {paginatedRows.map((row, index) => (
                    <ActualTreeTableRow
                      key={row.id}
                      node={row}
                      index={index}
                      isExpanded={expandedIds.has(row.id)}
                      isLoading={loadingIds.has(row.id)}
                      onToggle={handleToggle}
                      maxVisibleLevel={maxVisibleLevel}
                      activeMetrics={activeHierarchyConfig.availableMetrics}
                    />
                  ))}
                </AnimatePresence>
              </TableBody>
            </Table>
          ) : null}
        </TableContainer>

        <Box
          sx={{
            bgcolor: "background.paper",
            borderTop: 1,
            borderColor: "divider",
            px: 2,
            display: "flex",
            justifyContent: "space-between",
            alignItems: "center",
            minHeight: 40,
          }}
        >
          <Box sx={{ display: "flex", alignItems: "center", gap: 1 }}>
            <Box
              sx={{
                width: 8,
                height: 8,
                borderRadius: "50%",
                bgcolor: isSetupComplete ? "success.main" : "action.disabled",
              }}
            />
            <Typography
              variant="caption"
              color="text.secondary"
              fontWeight={500}
            >
              {isSetupComplete ? "Connected & Synced" : "No Connection"}
            </Typography>
          </Box>
          <TablePagination
            component="div"
            count={visibleRows.length}
            page={page}
            onPageChange={handleChangePage}
            rowsPerPage={rowsPerPage}
            onRowsPerPageChange={handleChangeRowsPerPage}
            rowsPerPageOptions={[10, 25, 50, 100]}
            sx={{
              ".MuiTablePagination-toolbar": { minHeight: 40, padding: 0 },
            }}
          />
        </Box>
      </Paper>
    </Box>
  );
}

