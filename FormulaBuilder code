// MAIN APPLICATION COMPONENT
// ============================================================================
export default function AdvancedBidirectionalBuilder() {
  const [rootNode, setRootNode] = useState(createNode('EMPTY'));
  const [clipboard, setClipboard] = useState(null);
  
  // Importer State
  const [importText, setImportText] = useState('');
  const [importError, setImportError] = useState(null);

  const jexlOutput = compileJexl(rootNode);
  const isComplete = !jexlOutput.includes('___');

  const handleImport = () => {
    setImportError(null);
    if (!importText.trim()) return;
    try {
      const ast = parseJexlToAST(importText);
      setRootNode(ast);
      setImportText(''); // Clear on success
    } catch (err) {
      setImportError(err.message);
    }
  };

  // Demo shortcut
  const loadDemo = () => {
    setImportText('(DebitPos < 0 ? math:abs(DebitPos) : -1 * DebitPos) > SwingNeg ? (SwingNeg + DebitPos) : (DebitPos < 0 ? math:abs(DebitPos) : -1 * DebitPos)');
  };

  return (
    <div className="min-h-screen bg-slate-100 p-6 font-sans text-slate-800">
      <div className="max-w-6xl mx-auto space-y-6">
        
        {/* Header */}
        <div className="bg-white p-6 rounded-xl shadow-sm border border-slate-200 flex justify-between items-center">
          <div>
            <h1 className="text-2xl font-bold text-slate-900 flex items-center gap-2">
              <Calculator className="text-blue-600" />
              Bidirectional Formula Builder
            </h1>
            <p className="text-sm text-slate-500 mt-1">
              Build rules visually, or paste a raw JEXL string to auto-generate the visual blocks.
            </p>
          </div>
          <div className="flex gap-3">
             <button 
              onClick={() => { setRootNode(createNode('EMPTY')); setClipboard(null); setImportError(null); }}
              className="px-4 py-2 text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-lg font-medium transition-colors"
            >
              Reset Canvas
            </button>
            <button 
              disabled={!isComplete || rootNode.type === 'EMPTY'}
              className="bg-blue-600 hover:bg-blue-700 disabled:bg-slate-300 text-white px-6 py-2.5 rounded-lg font-medium flex items-center gap-2 transition-colors"
            >
              <CheckCircle2 size={18} />
              Save Formula
            </button>
          </div>
        </div>

        {/* IMPORTER / PARSER SECTION */}
        <div className="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
          <div className="bg-slate-50 p-4 border-b border-slate-200 flex justify-between items-center">
            <h2 className="font-semibold text-slate-700 flex items-center gap-2">
              <UploadCloud size={18} className="text-blue-500" />
              Paste JEXL Formula
            </h2>
            <button onClick={loadDemo} className="text-xs text-blue-600 font-medium hover:underline">
              Load Example
            </button>
          </div>
          <div className="p-4 flex flex-col gap-3">
            <div className="flex gap-3">
              <textarea 
                value={importText}
                onChange={e => setImportText(e.target.value)}
                placeholder="Paste your raw formula here e.g., ((DebitPos < 0) ? math:abs(DebitPos) : -1 * DebitPos)..."
                className="flex-1 border border-slate-300 rounded-lg p-3 text-sm font-mono h-20 focus:ring-2 focus:ring-blue-500 outline-none resize-none"
              />
              <button 
                onClick={handleImport}
                className="bg-slate-800 hover:bg-slate-900 text-white px-6 rounded-lg font-medium transition-colors whitespace-nowrap"
              >
                Parse & Build UI
              </button>
            </div>
            {importError && (
              <div className="bg-red-50 text-red-600 border border-red-200 px-4 py-2 rounded-lg text-sm flex items-center gap-2">
                <AlertCircle size={16} />
                <strong>Syntax Error:</strong> {importError}
              </div>
            )}
          </div>
        </div>

        {/* BUILDER CANVAS */}
        <div className="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
          <div className="bg-slate-800 p-4 border-b border-slate-700 flex justify-between items-center text-white">
            <h2 className="font-semibold flex items-center gap-2">
              <GitBranch size={18} className="text-blue-400" />
              Visual Rule Canvas
            </h2>
            {clipboard && (
              <span className="text-xs font-medium bg-blue-500/20 text-blue-300 px-3 py-1 rounded-full border border-blue-500/30 flex items-center gap-1">
                <Copy size={12}/> Block copied to clipboard
              </span>
            )}
          </div>
          
          <div className="p-8 min-h-[400px] overflow-x-auto bg-slate-50/50">
            {rootNode.type === 'EMPTY' && (
               <div className="mb-6 p-4 bg-blue-50 border border-blue-100 rounded-xl text-blue-800 text-sm flex items-start gap-3 max-w-2xl">
                 <div className="p-2 bg-blue-100 rounded-full text-blue-600"><ArrowRight size={16}/></div>
