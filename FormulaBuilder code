          </div>
          <div className="p-4">
            <code className={`block w-full text-sm font-mono leading-relaxed break-all ${isComplete && rootNode.type !== 'EMPTY' ? 'text-emerald-400' : 'text-slate-500'}`}>
              {jexlOutput === '___' ? 'Start building to see output...' : jexlOutput}
            </code>
          </div>
        </div>

      </div>
    </div>
  );
}

