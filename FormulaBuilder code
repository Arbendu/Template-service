import React, { useState, useEffect } from 'react';
import { 
  Calculator, Plus, Trash2, GitBranch, Binary, Hash, 
  Variable, FunctionSquare, ArrowRight, CheckCircle2, 
  Copy, ClipboardPaste, UploadCloud, AlertCircle 
} from 'lucide-react';

// ============================================================================
// CONFIGURATION & MOCK DATA
// ============================================================================
const VARIABLES = [
  { id: 'DebitPos', label: 'Debit Position', type: 'NUMBER' },
  { id: 'SwingNeg', label: 'Swing Negative', type: 'NUMBER' },
  { id: 'Balance', label: 'Account Balance', type: 'NUMBER' },
  { id: '$G{REPORT_DATE}', label: 'Report Date', type: 'DATE' }
];

const OPERATORS = [
  { id: '+', label: '+' }, { id: '-', label: '-' }, 
  { id: '*', label: '×' }, { id: '/', label: '÷' },
  { id: '>', label: '>' }, { id: '<', label: '<' },
  { id: '>=', label: '≥' }, { id: '<=', label: '≤' },
  { id: '==', label: '=' }, { id: '!=', label: '≠' }
];

const FUNCTIONS = [
  { id: 'math:abs', label: 'Absolute Value' },
  { id: 'math:round', label: 'Round Number' },
  { id: 'math:min', label: 'Minimum' },
  { id: 'math:max', label: 'Maximum' }
];

// ============================================================================
// AST NODE FACTORY
// ============================================================================
const generateId = () => Math.random().toString(36).substring(2, 9);

const createNode = (type, clipboardNode = null) => {
  if (clipboardNode && type === 'PASTE') {
    const clone = JSON.parse(JSON.stringify(clipboardNode));
    // Regenerate IDs recursively to avoid React key collisions
    const regenIds = (node) => {
      if(!node) return;
      node.id = generateId();
      if(node.left) regenIds(node.left);
      if(node.right) regenIds(node.right);
      if(node.arg) regenIds(node.arg);
      if(node.condition) regenIds(node.condition);
      if(node.trueBranch) regenIds(node.trueBranch);
      if(node.falseBranch) regenIds(node.falseBranch);
    };
    regenIds(clone);
    return clone;
  }

  const base = { id: generateId(), type };
  switch (type) {
    case 'IF_ELSE':
      return { ...base, condition: createNode('EMPTY'), trueBranch: createNode('EMPTY'), falseBranch: createNode('EMPTY') };
    case 'BINARY_OP':
      return { ...base, left: createNode('EMPTY'), operator: '+', right: createNode('EMPTY') };
    case 'FUNCTION':
      return { ...base, funcName: 'math:abs', arg: createNode('EMPTY') };
    case 'VAR':
      return { ...base, value: VARIABLES[0].id };
    case 'NUMBER':
      return { ...base, value: 0 };
    case 'EMPTY':
    default:
      return base;
  }
};

// ============================================================================
// PARSER: JEXL -> AST (Lexer & Recursive Descent Parser)
// ============================================================================
const parseJexlToAST = (input) => {
  // 1. Lexer (Tokenizer)
  const tokens = [];
  let i = 0;
  while (i < input.length) {
    let char = input[i];
    if (/\s/.test(char)) { i++; continue; }
    
    if (char === '(' || char === ')' || char === '?' || char === ':') {
      tokens.push({ type: 'PUNCT', value: char }); i++; continue;
    }
    
    // Multi-char operators
    const nextTwo = input.substring(i, i + 2);
    if (['<=', '>=', '==', '!='].includes(nextTwo)) {
      tokens.push({ type: 'OP', value: nextTwo }); i += 2; continue;
    }
    
    // Single char operators
    if ("+-*/><".includes(char)) {
      tokens.push({ type: 'OP', value: char }); i++; continue;
    }
    
    // Numbers
    if (/[0-9.]/.test(char)) {
      let num = '';
      while (i < input.length && /[0-9.]/.test(input[i])) num += input[i++];
      tokens.push({ type: 'NUM', value: parseFloat(num) }); continue;
    }
    
    // Identifiers (Variables, Namespaces, Globals like $G{...})
    if (/[a-zA-Z_$]/.test(char)) {
      let id = '';
      // Allow curly braces for $G{...} and colons for math:abs
      while (i < input.length && /[a-zA-Z0-9_{}:.$]/.test(input[i])) id += input[i++];
      tokens.push({ type: 'ID', value: id }); continue;
    }
    
    throw new Error(`Unexpected character at index ${i}: ${char}`);
  }

  // 2. Parser (Recursive Descent)
  let current = 0;
  
  const peek = () => tokens[current];
  const next = () => tokens[current++];
  const consume = (expected) => {
    if (current < tokens.length && tokens[current].value === expected) {
      current++; return true;
    }
    return false;
  };

  const PRECEDENCE = {
    '==': 1, '!=': 1, '<': 2, '>': 2, '<=': 2, '>=': 2,
    '+': 3, '-': 3,
    '*': 4, '/': 4
  };

  const parsePrimary = () => {
    const t = next();
    if (!t) throw new Error("Unexpected end of expression");
    
    if (t.type === 'NUM') return { id: generateId(), type: 'NUMBER', value: t.value };
    
    if (t.type === 'ID') {
      // Function Check
      if (current < tokens.length && peek().value === '(') {
        consume('(');
        const arg = parseExpression();
        if (!consume(')')) throw new Error(`Expected ')' after function ${t.value}`);
        return { id: generateId(), type: 'FUNCTION', funcName: t.value, arg };
      }
      return { id: generateId(), type: 'VAR', value: t.value };
    }
    
    if (t.type === 'PUNCT' && t.value === '(') {
      const node = parseExpression();
      if (!consume(')')) throw new Error("Expected closing parenthesis ')'");
      return node;
    }
    
    if (t.type === 'OP' && t.value === '-') {
      // Unary Minus Handling (e.g. -1 * DebitPos -> Parses as NUMBER(-1) or BINARY(0 - x))
      const rightToken = peek();
      if (rightToken && rightToken.type === 'NUM') {
        next();
        return { id: generateId(), type: 'NUMBER', value: -rightToken.value };
      }
      // Or explicit -1 * logic if spaced differently
      const right = parsePrimary();
      return { 
        id: generateId(), type: 'BINARY_OP', 
        left: { id: generateId(), type: 'NUMBER', value: -1 }, 
        operator: '*', right 
      };
    }
    
    throw new Error(`Unexpected token: ${t.value}`);
  };

  const parseBinary = (minPrec) => {
    let left = parsePrimary();
    while (current < tokens.length && peek().type === 'OP' && PRECEDENCE[peek().value] >= minPrec) {
      const op = next().value;
      const prec = PRECEDENCE[op];
      const right = parseBinary(prec + 1);
      left = { id: generateId(), type: 'BINARY_OP', left, operator: op, right };
    }
    return left;
  };

  const parseExpression = () => {
    let node = parseBinary(0);
    // Ternary Handler
    if (consume('?')) {
      const trueBranch = parseExpression();
      if (!consume(':')) throw new Error("Expected ':' in ternary condition");
      const falseBranch = parseExpression();
      return { id: generateId(), type: 'IF_ELSE', condition: node, trueBranch, falseBranch };
    }
    return node;
  };

  const ast = parseExpression();
  if (current < tokens.length) throw new Error("Unexpected tokens at end of expression. Check your parentheses.");
  return ast;
};

// ============================================================================
// COMPILER: AST -> JEXL
// ============================================================================
const compileJexl = (node) => {
  if (!node) return "";
  switch (node.type) {
    case 'EMPTY': 
      return "___";
    case 'VAR': 
    case 'NUMBER': 
      return node.value;
    case 'BINARY_OP': 
      return `(${compileJexl(node.left)} ${node.operator} ${compileJexl(node.right)})`;
    case 'FUNCTION': 
      return `${node.funcName}(${compileJexl(node.arg)})`;
    case 'IF_ELSE': 
      return `(${compileJexl(node.condition)} ? ${compileJexl(node.trueBranch)} : ${compileJexl(node.falseBranch)})`;
    default: 
      return "";
  }
};

// ============================================================================
// RECURSIVE NODE UI COMPONENT
// ============================================================================
const ExpressionNode = ({ node, onChange, onRemove, clipboard, setClipboard }) => {
  if (!node) return null;

  // --- RENDERING EMPTY SLOT ---
  if (node.type === 'EMPTY') {
    return (
      <div className="relative group inline-block">
        <div className="flex items-center gap-1 px-3 py-2 bg-slate-100 border border-dashed border-slate-300 rounded-lg text-slate-500 hover:bg-white hover:border-blue-400 hover:text-blue-600 transition-all cursor-pointer">
          <Plus size={16} />
          <span className="text-sm font-medium">Add Block</span>
        </div>
        
        <div className="absolute top-full left-0 mt-1 w-48 bg-white border border-slate-200 shadow-xl rounded-xl p-1 z-10 hidden group-hover:block">
          <button onClick={() => onChange(createNode('VAR'))} className="w-full text-left px-3 py-2 text-sm hover:bg-slate-50 rounded-lg flex items-center gap-2"><Variable size={14} className="text-blue-500"/> Variable</button>
          <button onClick={() => onChange(createNode('NUMBER'))} className="w-full text-left px-3 py-2 text-sm hover:bg-slate-50 rounded-lg flex items-center gap-2"><Hash size={14} className="text-amber-500"/> Number</button>
          <button onClick={() => onChange(createNode('BINARY_OP'))} className="w-full text-left px-3 py-2 text-sm hover:bg-slate-50 rounded-lg flex items-center gap-2"><Binary size={14} className="text-emerald-500"/> Math / Compare</button>
          <button onClick={() => onChange(createNode('FUNCTION'))} className="w-full text-left px-3 py-2 text-sm hover:bg-slate-50 rounded-lg flex items-center gap-2"><FunctionSquare size={14} className="text-pink-500"/> Math Function</button>
          <div className="border-t border-slate-100 my-1"></div>
          <button onClick={() => onChange(createNode('IF_ELSE'))} className="w-full text-left px-3 py-2 text-sm hover:bg-purple-50 text-purple-700 font-medium rounded-lg flex items-center gap-2"><GitBranch size={14}/> If / Then / Else</button>
          
          {clipboard && (
            <>
              <div className="border-t border-slate-100 my-1"></div>
              <button onClick={() => onChange(createNode('PASTE', clipboard))} className="w-full text-left px-3 py-2 text-sm hover:bg-blue-50 text-blue-700 font-medium rounded-lg flex items-center gap-2">
                <ClipboardPaste size={14}/> Paste Copied Block
              </button>
            </>
          )}
        </div>
      </div>
    );
  }

  // Common Wrapper
  const BlockWrapper = ({ children, colorClass, title, icon: Icon }) => (
    <div className={`relative flex flex-col gap-2 p-3 rounded-xl border-2 ${colorClass} bg-white shadow-sm transition-all`}>
      <div className="flex justify-between items-center mb-1">
        <span className={`text-xs font-bold uppercase tracking-wider flex items-center gap-1.5 ${colorClass.replace('border-', 'text-').replace('-200', '-600').replace('-300', '-700')}`}>
          <Icon size={14} /> {title}
        </span>
        <div className="flex gap-1 opacity-0 hover:opacity-100 transition-opacity absolute right-2 top-2">
           <button onClick={() => setClipboard(node)} className="p-1 text-slate-400 hover:text-blue-600 bg-white rounded-md shadow-sm border border-slate-200" title="Copy Block">
            <Copy size={14} />
          </button>
          <button onClick={onRemove} className="p-1 text-slate-400 hover:text-red-600 bg-white rounded-md shadow-sm border border-slate-200">
            <Trash2 size={14} />
          </button>
        </div>
      </div>
      {children}
    </div>
  );

  // --- LEAF NODES ---
  if (node.type === 'VAR') {
    // If parsed variable isn't in mock data, show it anyway as custom
    const isKnownVar = VARIABLES.find(v => v.id === node.value);
    return (
      <div className="inline-flex items-center gap-1">
        <select 
          value={isKnownVar ? node.value : 'CUSTOM'} 
          onChange={(e) => onChange({ ...node, value: e.target.value })}
          className="bg-blue-50 border border-blue-200 text-blue-800 text-sm font-semibold rounded-lg px-3 py-1.5 focus:ring-2 focus:ring-blue-400 outline-none"
        >
          {VARIABLES.map(v => <option key={v.id} value={v.id}>{v.label}</option>)}
          {!isKnownVar && <option value="CUSTOM">{node.value} (Custom)</option>}
        </select>
        <button onClick={onRemove} className="text-slate-300 hover:text-red-500"><Trash2 size={14}/></button>
      </div>
    );
  }

  if (node.type === 'NUMBER') {
    return (
      <div className="inline-flex items-center gap-1">
        <input 
          type="number" 
          value={node.value} 
          onChange={(e) => onChange({ ...node, value: e.target.value })}
          className="bg-amber-50 border border-amber-200 text-amber-800 text-sm font-bold rounded-lg px-3 py-1.5 w-24 focus:ring-2 focus:ring-amber-400 outline-none"
        />
        <button onClick={onRemove} className="text-slate-300 hover:text-red-500"><Trash2 size={14}/></button>
      </div>
    );
  }

  // --- LOGIC NODES ---
  if (node.type === 'BINARY_OP') {
    return (
      <BlockWrapper colorClass="border-slate-300" title="Calculate / Compare" icon={Binary}>
        <div className="flex flex-wrap items-center gap-2">
          <ExpressionNode node={node.left} onChange={(n) => onChange({...node, left: n})} onRemove={() => onChange({...node, left: createNode('EMPTY')})} setClipboard={setClipboard} clipboard={clipboard} />
          <select 
            value={node.operator} 
            onChange={(e) => onChange({ ...node, operator: e.target.value })}
            className="bg-slate-100 border border-slate-300 text-slate-800 text-sm font-bold rounded-lg px-2 py-1.5 outline-none"
          >
            {OPERATORS.map(o => <option key={o.id} value={o.id}>{o.label}</option>)}
          </select>
          <ExpressionNode node={node.right} onChange={(n) => onChange({...node, right: n})} onRemove={() => onChange({...node, right: createNode('EMPTY')})} setClipboard={setClipboard} clipboard={clipboard} />
        </div>
      </BlockWrapper>
    );
  }

  if (node.type === 'FUNCTION') {
    const isKnownFunc = FUNCTIONS.find(f => f.id === node.funcName);
    return (
      <BlockWrapper colorClass="border-pink-300" title="Math Function" icon={FunctionSquare}>
        <div className="flex flex-wrap items-center gap-2">
          <select 
            value={isKnownFunc ? node.funcName : 'CUSTOM'} 
            onChange={(e) => onChange({ ...node, funcName: e.target.value })}
            className="bg-pink-50 border border-pink-200 text-pink-800 text-sm font-semibold rounded-lg px-3 py-1.5 outline-none"
          >
            {FUNCTIONS.map(f => <option key={f.id} value={f.id}>{f.label}</option>)}
            {!isKnownFunc && <option value="CUSTOM">{node.funcName}()</option>}
          </select>
          <span className="text-pink-300 font-bold">(</span>
          <ExpressionNode node={node.arg} onChange={(n) => onChange({...node, arg: n})} onRemove={() => onChange({...node, arg: createNode('EMPTY')})} setClipboard={setClipboard} clipboard={clipboard} />
          <span className="text-pink-300 font-bold">)</span>
        </div>
      </BlockWrapper>
    );
  }

  if (node.type === 'IF_ELSE') {
    return (
      <BlockWrapper colorClass="border-purple-300" title="Condition Rule" icon={GitBranch}>
        <div className="flex flex-col gap-3 pl-2">
          <div className="flex items-start gap-3">
            <span className="mt-2 text-xs font-bold bg-purple-100 text-purple-700 px-2 py-1 rounded">IF</span>
            <div className="flex-1">
              <ExpressionNode node={node.condition} onChange={(n) => onChange({...node, condition: n})} onRemove={() => onChange({...node, condition: createNode('EMPTY')})} setClipboard={setClipboard} clipboard={clipboard} />
            </div>
          </div>
          <div className="flex items-start gap-3 border-l-2 border-emerald-200 pl-4">
            <span className="mt-2 text-xs font-bold bg-emerald-100 text-emerald-700 px-2 py-1 rounded">THEN</span>
            <div className="flex-1">
              <ExpressionNode node={node.trueBranch} onChange={(n) => onChange({...node, trueBranch: n})} onRemove={() => onChange({...node, trueBranch: createNode('EMPTY')})} setClipboard={setClipboard} clipboard={clipboard} />
            </div>
          </div>
          <div className="flex items-start gap-3 border-l-2 border-rose-200 pl-4">
            <span className="mt-2 text-xs font-bold bg-rose-100 text-rose-700 px-2 py-1 rounded">ELSE</span>
            <div className="flex-1">
              <ExpressionNode node={node.falseBranch} onChange={(n) => onChange({...node, falseBranch: n})} onRemove={() => onChange({...node, falseBranch: createNode('EMPTY')})} setClipboard={setClipboard} clipboard={clipboard} />
            </div>
          </div>
        </div>
      </BlockWrapper>
    );
  }

  return null;
};

