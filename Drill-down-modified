  MASTER_HIERARCHY: {
    id: "MASTER_HIERARCHY",
    label: "Global Master Hierarchy",
    hierarchy: [
      "comp_code",
      "CGL_Number",
      "Circle_name",
      "Product",
      "Branch_name",
