import { useState, useMemo, useCallback, useEffect, memo } from "react";
import { useSelector } from "react-redux";
import {
  Box,
  Paper,
  Table,
  TableBody,
  TableCell,
  TableContainer,
  TableHead,
  TableRow,
  Typography,
  IconButton,
  CircularProgress,
  MenuItem,
  Select,
  FormControl,
  InputLabel,
  TablePagination,
} from "@mui/material";
import AnalyticsIcon from "@mui/icons-material/Analytics";
import ChevronRightIcon from "@mui/icons-material/ChevronRight";
import DatasetIcon from "@mui/icons-material/Dataset";
import useApi from "../../hooks/useApi";
import useCustomSnackbar from "../../utils/useCustomSnackbar";

// --- CONFIGURATION & CONSTANTS ---
const moduleType = "WHOLE_BANK";

const formatCurrency = (value) => {
  return new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: "INR",
  }).format(value || 0);
};

// Hierarchy Configurations (View Types)
const HIERARCHY_VIEWS = {
  CIRCLE_WISE: {
    id: "CIRCLE_WISE",
    label: "Circle Wise View",
    hierarchy: ["Circle_name", "Branch_name", "comp_code", "CGL_Number"],
  },
  BRANCH_WISE: {
    id: "BRANCH_WISE",
    label: "Branch Wise View",
    hierarchy: ["Branch_name", "comp_code", "CGL_Number", "Product"],
  },
};

// --- ACTUAL API LOGIC ---

const fetchAnalyticsData = async (callApi, payload) => {
  try {
    const responseData = await callApi(
      "/AS/analytics-reports/drill-down",
      payload,
      "POST",
    );
    return responseData?.data || [];
  } catch (error) {
    console.error("Error fetching analytics data:", error);
    showSnackBar("Failed to fetch analytics data", "error");
    //throw error;
  }
};

const fetchInitialData = async (callApi, hierarchy, fileName) => {
  const rootDimension = hierarchy[0];
  const payload = {
    fileName: fileName,
    dimensions: [rootDimension],
    metrics: ["jan", "feb", "mar"],
    hierarchy: hierarchy,
    filters: [],
  };

  const apiData = await fetchAnalyticsData(callApi, payload);

  return apiData.map((row) => ({
    ...row,
    level: 0,
    nodeFilters: [],
  }));
};

const fetchChildrenData = async (callApi, parentNode, hierarchy, fileName) => {
  const childLevel = parentNode.level + 1;
  const nextDimension = hierarchy[childLevel];

  const currentFilters = [
    ...(parentNode.nodeFilters || []),
    {
      field: hierarchy[parentNode.level],
      operator: "EQUALS",
      value: parentNode.name,
    },
  ];

  const payload = {
    fileName: fileName,
    dimensions: [nextDimension],
    metrics: ["jan", "feb", "mar"],
    hierarchy: hierarchy,
    filters: currentFilters,
  };

  const apiData = await fetchAnalyticsData(callApi, payload);

  return apiData.map((row) => ({
    ...row,
    level: childLevel,
    nodeFilters: currentFilters,
  }));
};

// --- COMPONENTS ---

// 1. The MUI Row Component
const TreeTableRow = memo(
  ({ node, isExpanded, isLoading, onToggle, maxVisibleLevel }) => {
    const total = (node.jan || 0) + (node.feb || 0) + (node.mar || 0);

    return (
      <TableRow hover>
        {Array.from({ length: maxVisibleLevel + 1 }).map((_, colIndex) => {
          if (colIndex === node.level) {
            return (
              <TableCell
                key={colIndex}
                sx={{
                  borderRight: 1,
                  borderColor: "divider",
                  minWidth: 220,
                  bgcolor: "background.paper",
                }}
              >
                <Box
                  sx={{
                    display: "flex",
                    alignItems: "center",
                    pl: node.level * 3,
                  }}
                >
                  {node.hasChildren ? (
                    <IconButton
                      size="small"
                      color="primary"
                      onClick={() => onToggle(node)}
                      disabled={isLoading}
                      sx={{
                        mr: 1.5,
                        border: 1,
                        borderColor: "divider",
                        borderRadius: "50%",
                        height: 22,
                        width: 22,
                        p: 0.3,
                        bgcolor: "action.hover",
                        "&:hover": { bgcolor: "action.selected" },
                      }}
                    >
                      {isLoading ? (
                        <CircularProgress size={14} color="inherit" />
                      ) : isExpanded ? (
                        "-"
                      ) : (
                        "+"
                      )}
                    </IconButton>
                  ) : (
                    <Box sx={{ width: 26, mr: 1.5 }} />
                  )}
                  <Typography
                    variant="body2"
                    color="text.primary"
                    sx={{ fontWeight: node.level === 0 ? 600 : 400 }}
                  >
                    {node.name}
                  </Typography>
                </Box>
              </TableCell>
            );
          }
          return (
            <TableCell
              key={colIndex}
              sx={{
                borderRight: 1,
                borderColor: "divider",
                minWidth: 150,
                bgcolor: "background.default",
              }}
            />
          );
        })}

        <TableCell
          align="right"
          sx={{
            borderRight: 1,
            borderColor: "divider",
            color: "text.secondary",
          }}
        >
          {formatCurrency(node.jan)}
        </TableCell>
        <TableCell
          align="right"
          sx={{
            borderRight: 1,
            borderColor: "divider",
            color: "text.secondary",
          }}
        >
          {formatCurrency(node.feb)}
        </TableCell>
        <TableCell
          align="right"
          sx={{
            borderRight: 1,
            borderColor: "divider",
            color: "text.secondary",
          }}
        >
          {formatCurrency(node.mar)}
        </TableCell>
        <TableCell
          align="right"
          sx={{
            fontWeight: 600,
            bgcolor: "action.hover",
            color: "text.primary",
          }}
        >
          {formatCurrency(total)}
        </TableCell>
      </TableRow>
    );
  },
);
TreeTableRow.displayName = "TreeTableRow";

// 2. The Main Screen Component
export default function ReportAnalysisScreen() {
  const { callApi } = useApi();
  const user = useSelector((state) => state.auth.user);
  const showSnackBar = useCustomSnackbar();

  // Dropdown & Config State
  const [availableReports, setAvailableReports] = useState([]);
  const [selectedReportFile, setSelectedReportFile] = useState("");
  const [activeHierarchyKey, setActiveHierarchyKey] = useState(
    HIERARCHY_VIEWS.CIRCLE_WISE.id,
  );

  // Data State
  const [data, setData] = useState([]);
  const [expandedIds, setExpandedIds] = useState(new Set());
  const [loadingIds, setLoadingIds] = useState(new Set());
  const [isInitializing, setIsInitializing] = useState(false);

  // Pagination State
  const [page, setPage] = useState(0);
  const [rowsPerPage, setRowsPerPage] = useState(10);

  const activeHierarchyConfig = HIERARCHY_VIEWS[activeHierarchyKey];

  // Derive the active report name for the UI Header
  const activeReportName = useMemo(() => {
    if (!selectedReportFile) return "Financial Analytics";
    const reportObj = availableReports.find(
      (r) => r.fileName === selectedReportFile,
    );
    return reportObj ? reportObj.reportName : "Financial Analytics";
  }, [selectedReportFile, availableReports]);

  // 1. Fetch available reports for the dropdown on mount
  useEffect(() => {
    const fetchReportTypes = async () => {
      try {
        const payload = {
          roleId: user?.role,
          moduleType: moduleType,
        };

        const response = await callApi("/RS/reports/types", payload, "POST");
        setAvailableReports(response?.data || []);
      } catch (error) {
        console.error("Failed to fetch report types", error);
        showSnackBar("Failed to fetch report types", "error");
      }
    };

    if (user) {
      fetchReportTypes();
    }
  }, [callApi, user]);

  // Reset page when report type or hierarchy changes
  useEffect(() => {
    setPage(0);
  }, [selectedReportFile, activeHierarchyKey]);

  // 2. Fetch Drill-Down Root Data when configurations change
  useEffect(() => {
    const loadRoot = async () => {
      if (!selectedReportFile) {
        setData([]);
        return;
      }

      setIsInitializing(true);
      setData([]);
      setExpandedIds(new Set());

      try {
        const rootData = await fetchInitialData(
          callApi,
          activeHierarchyConfig.hierarchy,
          selectedReportFile,
        );
        setData(rootData);
      } catch (error) {
        console.error("Failed to load initial data", error);
      } finally {
        setIsInitializing(false);
      }
    };
    loadRoot();
  }, [
    selectedReportFile,
    activeHierarchyKey,
    activeHierarchyConfig.hierarchy,
    callApi,
  ]);

  const appendChildrenToTree = useCallback((nodes, parentId, newChildren) => {
    return nodes.map((node) => {
      if (node.id === parentId) return { ...node, children: newChildren };
      if (node.children)
        return {
          ...node,
          children: appendChildrenToTree(node.children, parentId, newChildren),
        };
      return node;
    });
  }, []);

  const handleToggle = useCallback(
    async (node) => {
      const isExpanded = expandedIds.has(node.id);

      if (isExpanded) {
        setExpandedIds((prev) => {
          const next = new Set(prev);
          next.delete(node.id);
          return next;
        });
      } else {
        if (!node.children && node.hasChildren) {
          setLoadingIds((prev) => new Set(prev).add(node.id));
          try {
            const children = await fetchChildrenData(
              callApi,
              node,
              activeHierarchyConfig.hierarchy,
              selectedReportFile,
            );
            setData((prevData) =>
              appendChildrenToTree(prevData, node.id, children),
            );
          } catch (error) {
            console.error("Failed to fetch children", error);
          } finally {
            setLoadingIds((prev) => {
              const next = new Set(prev);
              next.delete(node.id);
              return next;
            });
          }
        }
        setExpandedIds((prev) => new Set(prev).add(node.id));
      }
    },
    [
      expandedIds,
      appendChildrenToTree,
      activeHierarchyConfig.hierarchy,
      selectedReportFile,
      callApi,
    ],
  );

  const visibleRows = useMemo(() => {
    const rows = [];
    const traverse = (nodes) => {
      for (const node of nodes) {
        rows.push(node);
        if (expandedIds.has(node.id) && node.children) traverse(node.children);
      }
    };
    traverse(data);
    return rows;
  }, [data, expandedIds]);

  const maxVisibleLevel = useMemo(() => {
    if (visibleRows.length === 0) return 0;
    return Math.max(...visibleRows.map((row) => row.level));
  }, [visibleRows]);

  const visibleHierarchyLevels = activeHierarchyConfig.hierarchy.slice(
    0,
    maxVisibleLevel + 1,
  );

  const paginatedRows = useMemo(() => {
    const startIndex = page * rowsPerPage;
    return visibleRows.slice(startIndex, startIndex + rowsPerPage);
  }, [visibleRows, page, rowsPerPage]);

  const handleChangePage = (event, newPage) => setPage(newPage);

  const handleChangeRowsPerPage = (event) => {
    setRowsPerPage(parseInt(event.target.value, 10));
    setPage(0);
  };

  return (
    <Box>
      <Paper
        elevation={0}
        sx={{
          mx: "auto",
          height: "calc(100vh - 64px)",
          display: "flex",
          flexDirection: "column",
          overflow: "hidden",
          borderRadius: 1,
          boxShadow: "baseShadow",
          border: 1,
          borderColor: "divider",
        }}
      >
        {/* Top Header */}
        <Box
          sx={{
            bgcolor: "primary.main",
            px: 3,
            py: 2,
            display: "flex",
            justifyContent: "space-between",
            alignItems: "center",
          }}
        >
          <Box display="flex" alignItems="center" gap={2}>
            <Box
              sx={{
                backgroundColor: "primary.light",
                borderRadius: "50%",
                width: 50,
                height: 50,
                display: "flex",
                alignItems: "center",
                justifyContent: "center",
              }}
            >
              <AnalyticsIcon
                sx={{ color: "primary.contrastText", fontSize: 30 }}
              />
            </Box>
            <Box>
              <Typography
                variant="h6"
                sx={{ color: "primary.contrastText", fontWeight: 600 }}
              >
                {activeReportName}
              </Typography>
              <Typography
                variant="caption"
                sx={{ color: "primary.contrastText", opacity: 0.8 }}
              >
                Dynamic Drill-Down Matrix
              </Typography>
            </Box>
          </Box>
        </Box>

        {/* Toolbar Area */}
        <Box
          sx={{
            bgcolor: "background.glass",
            borderBottom: 1,
            borderColor: "divider",
            px: 3,
            py: 2,
            display: "flex",
            alignItems: "center",
            gap: 3,
          }}
        >
          {/* Dropdown 1: Select Database Report - FIXED OVERLAP */}
          <FormControl
            size="small"
            sx={{ minWidth: 300, bgcolor: "background.paper", borderRadius: 1 }}
          >
            {/* Added shrink={true} to strictly fix the label overlap */}
            <InputLabel id="report-source-label" shrink>
              Database Report
            </InputLabel>
            <Select
              labelId="report-source-label"
              value={selectedReportFile}
              label="Database Report"
              onChange={(e) => setSelectedReportFile(e.target.value)}
              displayEmpty
              notched // Ensures the border stays broken for the label
              MenuProps={{
                anchorOrigin: {
                  vertical: "bottom",
                  horizontal: "left",
                },
                transformOrigin: {
                  vertical: "top",
                  horizontal: "left",
                },
                PaperProps: {
                  sx: {
                    bgcolor: "background.paper", // Forces a solid background so it doesn't look transparent
                    boxShadow: 3,
                  },
                },
              }}
            >
              <MenuItem value="" disabled>
                <em>Please select the report</em>
              </MenuItem>
              {availableReports.map((report) => (
                <MenuItem key={report.fileName} value={report.fileName}>
                  {report.reportName}
                </MenuItem>
              ))}
            </Select>
          </FormControl>

          {/* Dropdown 2: Select Hierarchy View */}
          <FormControl
            size="small"
            sx={{ minWidth: 220, bgcolor: "background.paper", borderRadius: 1 }}
          >
            <InputLabel id="hierarchy-view-label">Hierarchy View</InputLabel>
            <Select
              labelId="hierarchy-view-label"
              value={activeHierarchyKey}
              label="Hierarchy View"
              onChange={(e) => setActiveHierarchyKey(e.target.value)}
              MenuProps={{
                anchorOrigin: {
                  vertical: "bottom",
                  horizontal: "left",
                },
                transformOrigin: {
                  vertical: "top",
                  horizontal: "left",
                },
                PaperProps: {
                  sx: {
                    bgcolor: "background.paper",
                    boxShadow: 3,
                    mt: 0.5,
                  },
                },
              }}
            >
              {Object.values(HIERARCHY_VIEWS).map((view) => (
                <MenuItem key={view.id} value={view.id}>
                  {view.label}
                </MenuItem>
              ))}
            </Select>
          </FormControl>

          <Box
            sx={{ borderLeft: 1, borderColor: "divider", height: 30, mx: 1 }}
          />

          {/* Redesigned Breadcrumb Path Area */}
          <Box display="flex" alignItems="center" gap={1}>
            <Typography
              variant="body2"
              color="text.secondary"
              sx={{ mr: 1, fontWeight: 500 }}
            >
              Path:
            </Typography>
            {activeHierarchyConfig.hierarchy.map((item, index) => (
              <Box key={index} display="flex" alignItems="center">
                <Box
                  sx={{
                    px: 1.5,
                    py: 0.5,
                    bgcolor: index === 0 ? "primary.main" : "background.paper",
                    color:
                      index === 0 ? "primary.contrastText" : "text.primary",
                    borderRadius: 1,
                    border: 1,
                    borderColor: index === 0 ? "primary.main" : "divider",
                    fontSize: "0.75rem",
                    fontWeight: 600,
                    textTransform: "capitalize",
                  }}
                >
                  {item.replace("_", " ")}
                </Box>
                {index < activeHierarchyConfig.hierarchy.length - 1 && (
                  <ChevronRightIcon
                    sx={{ mx: 0.5, color: "text.disabled", fontSize: 18 }}
                  />
                )}
              </Box>
            ))}
          </Box>
        </Box>

        {/* Material-UI Data Grid */}
        <TableContainer
          sx={{
            flexGrow: 1,
            bgcolor: "background.default",
            position: "relative",
          }}
        >
          {/* Empty State when no report is selected */}
          {!selectedReportFile && (
            <Box
              sx={{
                position: "absolute",
                top: 0,
                left: 0,
                right: 0,
                bottom: 0,
                display: "flex",
                flexDirection: "column",
                alignItems: "center",
                justifyContent: "center",
                zIndex: 10,
              }}
            >
              <DatasetIcon
                sx={{ fontSize: 60, color: "action.disabled", mb: 1 }}
              />
              <Typography variant="h6" color="text.secondary">
                No Data to Display
              </Typography>
              <Typography variant="body2" color="text.disabled">
                Please select a database report from the dropdown above to begin
                analysis.
              </Typography>
            </Box>
          )}

          {isInitializing ? (
            <Box
              sx={{
                height: "100%",
                display: "flex",
                flexDirection: "column",
                alignItems: "center",
                justifyContent: "center",
              }}
            >
              <CircularProgress size={40} color="primary" sx={{ mb: 2 }} />
              <Typography variant="body1" color="text.secondary">
                Executing Query ...
              </Typography>
            </Box>
          ) : (
            <Table stickyHeader size="small" sx={{ minWidth: 1000 }}>
              <TableHead>
                <TableRow>
                  {visibleHierarchyLevels.map((levelName) => (
                    <TableCell
                      key={levelName}
                      sx={{
                        bgcolor: "background.paper",
                        color: "text.primary",
                        fontWeight: 700,
                        borderRight: 1,
                        borderColor: "divider",
                        borderBottom: 2,
                        width: 220,
                      }}
                    >
                      {levelName.replace("_", " ").toUpperCase()}
                    </TableCell>
                  ))}
                  <TableCell
                    align="right"
                    sx={{
                      bgcolor: "background.paper",
                      color: "text.primary",
                      fontWeight: 700,
                      borderRight: 1,
                      borderColor: "divider",
                      borderBottom: 2,
                    }}
                  >
                    January
                  </TableCell>
                  <TableCell
                    align="right"
                    sx={{
                      bgcolor: "background.paper",
                      color: "text.primary",
                      fontWeight: 700,
                      borderRight: 1,
                      borderColor: "divider",
                      borderBottom: 2,
                    }}
                  >
                    February
                  </TableCell>
                  <TableCell
                    align="right"
                    sx={{
                      bgcolor: "background.paper",
                      color: "text.primary",
                      fontWeight: 700,
                      borderRight: 1,
                      borderColor: "divider",
                      borderBottom: 2,
                    }}
                  >
                    March
                  </TableCell>
                  <TableCell
                    align="right"
                    sx={{
                      bgcolor: "action.hover",
                      color: "text.primary",
                      fontWeight: 800,
                      borderBottom: 2,
                      borderColor: "divider",
                    }}
                  >
                    YTD Total
                  </TableCell>
                </TableRow>
              </TableHead>
              <TableBody>
                {paginatedRows.map((row) => (
                  <TreeTableRow
                    key={row.id}
                    node={row}
                    isExpanded={expandedIds.has(row.id)}
                    isLoading={loadingIds.has(row.id)}
                    onToggle={handleToggle}
                    maxVisibleLevel={maxVisibleLevel}
                  />
                ))}
              </TableBody>
            </Table>
          )}
        </TableContainer>

        {/* Footer Status Bar with Pagination */}
        <Box
          sx={{
            bgcolor: "background.glass",
            borderTop: 1,
            borderColor: "divider",
            px: 3,
            display: "flex",
            justifyContent: "space-between",
            alignItems: "center",
          }}
        >
          <Box sx={{ display: "flex", alignItems: "center", gap: 1 }}>
            <Box
              sx={{
                width: 8,
                height: 8,
                borderRadius: "50%",
                bgcolor: selectedReportFile
                  ? "success.main"
                  : "action.disabled",
              }}
            />
            <Typography variant="caption" color="text.secondary">
              {selectedReportFile ? "Connected" : "No Connection"}
            </Typography>
          </Box>

          <TablePagination
            component="div"
            count={visibleRows.length}
            page={page}
            onPageChange={handleChangePage}
            rowsPerPage={rowsPerPage}
            onRowsPerPageChange={handleChangeRowsPerPage}
            rowsPerPageOptions={[10, 25, 50, 100]}
            sx={{
              ".MuiTablePagination-toolbar": { minHeight: 50, padding: 0 },
              ".MuiTablePagination-selectLabel, .MuiTablePagination-displayedRows":
                { margin: 0, color: "text.secondary" },
            }}
          />
        </Box>
      </Paper>
    </Box>
  );
}











