// DifferenceService

package com.fincore.enquiry_service.service;

import com.fincore.enquiry_service.dto.DifferenceDTO;
import com.fincore.enquiry_service.dto.DifferenceSearchDto;
import com.fincore.enquiry_service.repository.DifferenceRepository;
import io.micrometer.common.util.StringUtils;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.data.domain.Page;
import org.springframework.data.domain.PageRequest;
import org.springframework.data.domain.Sort;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

@Service
public class DifferenceService implements IDifferenceService {

    @Autowired
    private DifferenceRepository repository;

    @Transactional(readOnly = true)
    public Page<DifferenceDTO> getAllDifferences(int page, int size) {
        PageRequest pageRequest = PageRequest.of(page, size, Sort.by("id"));
        return repository.findAllAsDto(pageRequest);
    }

    @Transactional(readOnly = true)
    public Page<DifferenceDTO> searchDifferences(DifferenceSearchDto criteria, int page, int size) {
        PageRequest pageRequest = PageRequest.of(page, size, Sort.by("id"));

        // sanitize inputs: convert empty strings to null so SQL ignores them
        String branch = StringUtils.isBlank(criteria.getBranchCode()) ? null : criteria.getBranchCode();
        String curr = StringUtils.isBlank(criteria.getCurrency()) ? null : criteria.getCurrency();
        String cgl = StringUtils.isBlank(criteria.getCgl()) ? null : criteria.getCgl();

        return repository.searchDifferencesDynamic(
                criteria.getFromDate(),
                criteria.getEffectiveToDate(), // Handles the "Single Date vs Range" logic
                branch,
                curr,
                cgl,
                pageRequest
        );
    }
}









// DifferenceRepository

package com.fincore.enquiry_service.repository;

import com.fincore.enquiry_service.dto.DifferenceDTO;
import com.fincore.enquiry_service.model.Difference;
import org.springframework.data.domain.Page;
import org.springframework.data.domain.Pageable;
import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.data.jpa.repository.Query;
import org.springframework.data.repository.query.Param;
import org.springframework.stereotype.Repository;
import java.time.LocalDate;

@Repository
public interface DifferenceRepository extends JpaRepository<Difference, Long> {

    // 1. Keep the original 'Find All' for basic listing
    @Query("""
        SELECT new com.fincore.enquiry_service.dto.DifferenceDTO(
            d.reconRunDate, d.branchCode, d.currency, d.cgl,
            d.cbsBalance, d.glBalance, d.differenceAmount,
            d.diffBwYesterday, d.type, d.head, d.FIRST_ERROR_DATE
        )
        FROM Difference d
    """)
    Page<DifferenceDTO> findAllAsDto(Pageable pageable);

    /**
     * 2. MASTER DYNAMIC FILTER
     * Handles: Date Range, Optional Branch, Optional Currency, Optional CGL
     */
    @Query("""
        SELECT new  com.fincore.enquiry_service.dto.DifferenceDTO(
            d.reconRunDate, d.branchCode, d.currency, d.cgl,
            d.cbsBalance, d.glBalance, d.differenceAmount,
            d.diffBwYesterday, d.type, d.head, d.FIRST_ERROR_DATE
        )
        FROM Difference d
        WHERE (d.reconRunDate BETWEEN :fromDate AND :toDate)
        AND (:branchCode IS NULL OR d.branchCode = :branchCode)
        AND (:currency IS NULL OR d.currency = :currency)
        AND (:cgl IS NULL OR d.cgl = :cgl)
    """)
    Page<DifferenceDTO> searchDifferencesDynamic(
            @Param("fromDate") LocalDate fromDate,
            @Param("toDate") LocalDate toDate,
            @Param("branchCode") String branchCode,
            @Param("currency") String currency,
            @Param("cgl") String cgl,
            Pageable pageable
    );
}













