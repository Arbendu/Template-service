export const saveTemplate = async (callApi, payloadData) => {
  try {
    // 1. Drill down into the nested structure to find the IDs
    // Based on your Network tab: payload -> template -> templateMeta/reportMeta
    const templateId = payloadData?.template?.templateMeta?.templateId; // e.g., "999999"
    const reportId = payloadData?.template?.reportMeta?.reportId;       // e.g., ""

    // 2. Determine the targetId. Prefer reportId, fallback to templateId.
    const extractedId = reportId || templateId || null;

    // 3. Determine if it's an update. 
    // If reportId is an empty string, it's a new creation (ADD).
    const isUpdate = Boolean(reportId && reportId.trim() !== "");

    // 4. Construct the DTO
    const createRequestDto = {
      requestType: "RB_REPORT_TEMPLATE", 
      changeType: isUpdate ? "UPDATE" : "ADD", 
      
      // Pass the extracted ID explicitly to prevent the backend IllegalArgumentException
      targetId: extractedId ? String(extractedId) : null, 
      
      payload: payloadData 
    };

    const response = await callApi(
      "/CR/create-request", 
      JSON.stringify(createRequestDto),
      "POST"
    );

    return { 
      success: true, 
      requestId: response.id || response.requestId, 
      status: "PENDING_APPROVAL",
      action: isUpdate ? "UPDATE_SUBMITTED" : "ADD_SUBMITTED" 
    }; 

  } catch (error) {
    console.error("Error submitting template request:", error);
    return { success: false, error: error.message };
  }
};
