public class TemplateRequestValidationService {

    private static final Pattern SQL_IDENTIFIER_PATTERN = Pattern.compile("^[A-Za-z0-9_]+$");
    private static final Pattern ROW_ID_PATTERN = Pattern.compile("^R__[A-Za-z0-9]+$");
    private static final Pattern COL_ID_PATTERN = Pattern.compile("^C__[A-Za-z0-9]+$");
    private static final Pattern CELL_REF_PATTERN = Pattern.compile("cell_(R[A-Za-z0-9_]+)_(C[A-Za-z0-9_]+)");
    private static final Pattern TOKEN_PATTERN = Pattern.compile("[A-Za-z0-9_]+");
    private static final int MAX_TOTAL_SPECS = 5000;
    private static final int MAX_DYNAMIC_LIMIT = 10000;
    private static final Set<String> ALLOWED_PAGE_SIZES = Set.of("A4", "A3", "A5", "LETTER", "LEGAL");
    private static final Set<String> ALLOWED_ORIENTATIONS = Set.of("PORTRAIT", "LANDSCAPE");
    private static final Set<String> ALLOWED_ROW_TYPES = Set.of("DATA", "DYNAMIC", "HEADER", "FOOTER", "GROUP_START", "GROUP_END");
    private static final Set<String> ALLOWED_CELL_TYPES = Set.of("TEXT", "FORMULA", "DB_VALUE", "DB_SUM", "DB_COUNT", "DB_AVG", "DB_MIN", "DB_MAX", "DB_DATE", "DB_TEXT");
    private static final Set<String> ALLOWED_OPERATORS = Set.of("=", "!=", ">", "<", ">=", "<=", "LIKE", "IN", "BETWEEN");
    private static final Set<String> ALLOWED_VARIANT_SCOPES = Set.of("ALL_DB", "TABLE", "DYNAMIC_TABLE", "TAG");
    private static final Set<String> ALLOWED_PARAM_TYPES = Set.of("STRING", "NUMBER", "DATE", "LIST");
    private static final Set<String> VALID_ORDER_DIRECTIONS = Set.of("ASC", "DESC");
    private static final Set<String> IGNORED_KEYWORDS = Set.of(
            "null", "true", "false", "math", "abs", "min", "max", "round", "ceil", "floor",
            "size", "empty", "new", "and", "or", "not", "eq", "ne", "lt", "gt", "le", "ge", "div", "mod", "string");
    private static final JexlEngine JEXL = new JexlBuilder().silent(false).strict(true).create();

    private final AllowedTablesRepository allowedTablesRepository;
    private final ReportTemplateRepository reportTemplateRepository;

    public void validate(CreateTemplateRequestDto dto) {
        if (dto == null || dto.getPayload() == null || dto.getPayload().getTemplate() == null) {
            throw new BadRequestException("payload.template is required");
        }

        TemplatePayload.Template template = dto.getPayload().getTemplate();
        validateMetadata(template);
        validateColumns(template);
        validateCreateTemplateRequest(dto);
        assignIds(template);

        ValidationContext ctx = validateRowsAndCells(template);
        validateFormulasAndCircularDependencies(template);
        validateSchemaPermissions(ctx.dbRequirements);

        if (dto.getPayload().getVariants() != null) {
            validateVariants(dto.getPayload().getVariants(), ctx.tablesUsed);
        }

        if (ctx.totalEstimatedSpecs > MAX_TOTAL_SPECS) {
            throw new BadRequestException("Template complexity exceeded. Max allowed specs: " + MAX_TOTAL_SPECS);
        }
    }

    private void validateCreateTemplateRequest(CreateTemplateRequestDto dto) {
        String reportId = extractReportId(dto.getPayload());
        if (dto.getChangeType() == ChangeType.UPDATE) {
            if (!reportTemplateRepository.existsByReportIdAndStatus(reportId, "ACTIVE")) {
                throw new ValidationException("Cannot create UPDATE request. No ACTIVE template found for reportId: " + reportId);
            }
        } else if (dto.getChangeType() == ChangeType.DELETE) {
            if (!reportTemplateRepository.existsByReportIdAndStatus(reportId, "ACTIVE")) {
                throw new ValidationException("Cannot create DELETE request. No ACTIVE template found for reportId: " + reportId);
            }
        }
    }

    private void validateMetadata(TemplatePayload.Template t) {
        if (t.getTemplateMeta() == null) {
            throw new BadRequestException("templateMeta is required");
        }
        if (t.getReportMeta() == null) {
            throw new BadRequestException("reportMeta is required");
        }
        if (!StringUtils.hasText(t.getReportMeta().getReportName())) {
            throw new BadRequestException("reportMeta.reportName is required");
        }
        String pageSize = normalize(t.getTemplateMeta().getPageSize());
        if (pageSize != null && !ALLOWED_PAGE_SIZES.contains(pageSize)) {
            throw new BadRequestException("Invalid pageSize: " + t.getTemplateMeta().getPageSize());
        }
        String orientation = normalize(t.getTemplateMeta().getPageOrientation());
        if (orientation != null && !ALLOWED_ORIENTATIONS.contains(orientation)) {
            throw new BadRequestException("Invalid pageOrientation: " + t.getTemplateMeta().getPageOrientation());
        }
        if (t.getReportData() == null) {
            throw new BadRequestException("reportData is required");
        }
    }

    private void validateColumns(TemplatePayload.Template t) {
        List<TemplatePayload.ColumnDefinition> columns = t.getReportData().getColumns();
        if (columns == null || columns.isEmpty()) {
            throw new BadRequestException("At least one column is required");
        }

        Set<String> seen = new HashSet<>();
        for (TemplatePayload.ColumnDefinition column : columns) {
            if (!StringUtils.hasText(column.getId()) || !COL_ID_PATTERN.matcher(column.getId()).matches()) {
                throw new BadRequestException("Invalid column id: " + column.getId());
            }
            if (!seen.add(column.getId())) {
                throw new BadRequestException("Duplicate column id: " + column.getId());
            }
            if (!StringUtils.hasText(column.getName())) {
                throw new BadRequestException("Column name is required for id: " + column.getId());
            }
        }
    }

    private ValidationContext validateRowsAndCells(TemplatePayload.Template t) {
        ValidationContext ctx = new ValidationContext();
        List<TemplatePayload.Row> rows = t.getReportData().getRows();
        if (rows == null) {
            return ctx;
        }

        int columnCount = t.getReportData().getColumns().size();
        for (TemplatePayload.Row row : rows) {
            String rowId = row.getId();
            if (!StringUtils.hasText(rowId) || !ROW_ID_PATTERN.matcher(rowId).matches()) {
                throw new BadRequestException("Invalid row id: " + rowId);
            }

            String rowType = normalize(row.getRowType());
            if (!StringUtils.hasText(rowType) || !ALLOWED_ROW_TYPES.contains(rowType)) {
                throw new BadRequestException("Invalid rowType for row " + rowId + ": " + row.getRowType());
            }

            if ("DYNAMIC".equals(rowType)) {
                validateDynamicRow(row, ctx);
                continue;
            }

            if ("DATA".equals(rowType) && row.getCells() != null) {
                if (row.getCells().size() > columnCount) {
                    throw new BadRequestException("Row " + rowId + " exceeds column count");
                }
                for (TemplatePayload.Cell cell : row.getCells()) {
                    ctx.totalEstimatedSpecs += validateCell(cell, rowId, ctx);
                }
            }
        }
        return ctx;
    }

    private void validateDynamicRow(TemplatePayload.Row row, ValidationContext ctx) {
        Map<String, Object> cfg = row.getDynamicConfig();
        if (cfg == null) {
            throw new BadRequestException("dynamicConfig is required for row: " + row.getId());
        }

        String type = normalize(asString(cfg.get("type")));
        if (!"DB_LIST".equals(type)) {
            throw new BadRequestException("Only dynamicConfig.type=DB_LIST is supported");
        }

        String table = asString(cfg.get("table"));
        validateIdentifier(table, "Invalid dynamic table name");
        ctx.tablesUsed.add(table);

        List<String> select = toStringList(cfg.get("select"));
        if (select.isEmpty()) {
            throw new BadRequestException("dynamicConfig.select cannot be empty");
        }
        for (String column : select) {
            validateIdentifier(column, "Invalid dynamic select column");
            addRequirement(ctx.dbRequirements, table, new ColumnUsage(column, "DB_VALUE", false, true));
        }

        Integer limit = cfg.get("limit") == null ? 300 : toInteger(cfg.get("limit"));
        if (limit < 1 || limit > MAX_DYNAMIC_LIMIT) {
            throw new BadRequestException("dynamicConfig.limit must be between 1 and " + MAX_DYNAMIC_LIMIT);
        }

        validateFilters(castMap(cfg.get("filters")), row.getId(), table, ctx);

        if (cfg.get("orderby") != null) {
            List<String> parts = toOrderByParts(cfg.get("orderby"));
            for (String part : parts) {
                String normalized = part.trim();
                if (containsSqlInjectionPattern(normalized)) {
                    throw new BadRequestException("Invalid orderby clause: " + normalized);
                }
                String[] tokens = normalized.split("\\s+");
                String col = tokens[0];
                validateIdentifier(col, "Invalid orderby column");
                if (!select.contains(col)) {
                    throw new BadRequestException("orderby column must be in select list: " + col);
                }
                if (tokens.length > 1) {
                    String dir = normalize(tokens[1]);
                    if (!VALID_ORDER_DIRECTIONS.contains(dir)) {
                        throw new BadRequestException("Invalid order direction: " + tokens[1]);
                    }
                }
            }
        }

        ctx.totalEstimatedSpecs += (long) select.size() * limit;
    }

    private long validateCell(TemplatePayload.Cell cell, String rowId, ValidationContext ctx) {
        String type = normalize(cell.getType());
        if (!StringUtils.hasText(type) || !ALLOWED_CELL_TYPES.contains(type)) {
            throw new BadRequestException("Invalid cell type in row " + rowId + ": " + cell.getType());
        }

        if (cell.getRender() != null) {
            Integer colspan = toNullableInteger(cell.getRender().get("colspan"));
            Integer rowspan = toNullableInteger(cell.getRender().get("rowspan"));
            if (colspan != null && colspan <= 0) {
                throw new BadRequestException("render.colspan must be > 0");
            }
            if (rowspan != null && rowspan <= 0) {
                throw new BadRequestException("render.rowspan must be > 0");
            }
        }

        if (type.startsWith("DB_")) {
            Map<String, Object> source = cell.getSource();
            if (source == null) {
                throw new BadRequestException("source is required for DB cell");
            }
            String table = asString(source.get("table"));
            String column = asString(source.get("column"));
            validateIdentifier(table, "Invalid DB source table");
            validateIdentifier(column, "Invalid DB source column");
            ctx.tablesUsed.add(table);
            addRequirement(ctx.dbRequirements, table, new ColumnUsage(column, type, false, true));
            validateFilters(castMap(source.get("filters")), rowId, table, ctx);
            return 1;
        }

        if ("FORMULA".equals(type)) {
            return validateFormulaCell(cell, rowId, ctx);
        }

        return 0;
    }

    private long validateFormulaCell(TemplatePayload.Cell cell, String rowId, ValidationContext ctx) {
        if (!StringUtils.hasText(cell.getExpression())) {
            return 0;
        }

        try {
            JEXL.createExpression(cell.getExpression());
        } catch (JexlException e) {
            throw new BadRequestException("Invalid formula expression in row " + rowId + ": " + e.getMessage());
        }

        long inlineSpecs = 0;
        if (cell.getVariables() == null) {
            return inlineSpecs;
        }

        for (Map.Entry<String, Object> variable : cell.getVariables().entrySet()) {
            Object definition = variable.getValue();
            if (!(definition instanceof Map<?, ?> definitionMapRaw)) {
                continue;
            }
            Map<String, Object> definitionMap = castMap(definitionMapRaw);
            String type = normalize(asString(definitionMap.get("type")));
            if (type != null && type.startsWith("DB_")) {
                String table = asString(definitionMap.get("table"));
                String column = asString(definitionMap.get("column"));
                validateIdentifier(table, "Invalid formula variable table");
                validateIdentifier(column, "Invalid formula variable column");
                ctx.tablesUsed.add(table);
                addRequirement(ctx.dbRequirements, table, new ColumnUsage(column, type, false, true));
                validateFilters(castMap(definitionMap.get("filters")), rowId, table, ctx);
                inlineSpecs++;
            }
        }

        return inlineSpecs;
    }

    private void validateFilters(Map<String, Object> filters, String context, String tableName, ValidationContext ctx) {
        if (filters == null || filters.isEmpty()) {
            return;
        }

        for (Map.Entry<String, Object> filter : filters.entrySet()) {
            String column = filter.getKey();
            validateIdentifier(column, "Invalid filter column in " + context);
            addRequirement(ctx.dbRequirements, tableName, new ColumnUsage(column, null, true, false));

            if (filter.getValue() instanceof Map<?, ?> valueMapRaw) {
                Map<String, Object> valueMap = castMap(valueMapRaw);
                String op = normalize(asString(valueMap.get("op")));
                if (StringUtils.hasText(op) && !ALLOWED_OPERATORS.contains(op)) {
                    throw new BadRequestException("Unsupported filter operator: " + op);
                }

                Object value = valueMap.get("value");
                if ("IN".equals(op) && !(value instanceof List<?>)) {
                    throw new BadRequestException("IN filter expects list value for column " + column);
                }
                if ("BETWEEN".equals(op)) {
                    if (!(value instanceof List<?> values) || values.size() != 2) {
                        throw new BadRequestException("BETWEEN filter expects exactly 2 values for column " + column);
                    }
                }
            }
        }
    }

    private void validateFormulasAndCircularDependencies(TemplatePayload.Template t) {
        Map<String, TemplatePayload.Cell> allCells = new HashMap<>();
        for (TemplatePayload.Row row : defaultList(t.getReportData().getRows())) {
            for (TemplatePayload.Cell cell : defaultList(row.getCells())) {
                if (StringUtils.hasText(cell.getId())) {
                    allCells.put(cell.getId(), cell);
                }
            }
        }

        Map<String, Set<String>> graph = new HashMap<>();
        for (Map.Entry<String, TemplatePayload.Cell> entry : allCells.entrySet()) {
            String cellId = entry.getKey();
            TemplatePayload.Cell cell = entry.getValue();
            if (!"FORMULA".equals(normalize(cell.getType()))) {
                continue;
            }

            Set<String> deps = new HashSet<>();
            Set<String> vars = cell.getVariables() != null ? cell.getVariables().keySet() : Set.of();
            if (cell.getVariables() != null) {
                for (Object value : cell.getVariables().values()) {
                    if (value instanceof Map<?, ?> valueMapRaw) {
                        Map<String, Object> valueMap = castMap(valueMapRaw);
                        if ("CELL_REF".equals(normalize(asString(valueMap.get("type"))))) {
                            String ref = asString(valueMap.get("value"));
                            if (StringUtils.hasText(ref)) {
                                ensureCellReferenceExists(ref, allCells);
                                deps.add(ref);
                            }
                        }
                    }
                }
            }

            if (StringUtils.hasText(cell.getExpression())) {
                Matcher matcher = TOKEN_PATTERN.matcher(cell.getExpression());
                while (matcher.find()) {
                    String token = matcher.group();
                    if (vars.contains(token) || isNumeric(token) || IGNORED_KEYWORDS.contains(token.toLowerCase())) {
                        continue;
                    }
                    if (CELL_REF_PATTERN.matcher(token).matches()) {
                        ensureCellReferenceExists(token, allCells);
                        deps.add(token);
                        continue;
                    }
                    log.info("vars: ", vars);
                    throw new BadRequestException("Undefined reference in expression: " + token);
                }
            }
            graph.put(cellId, deps);
        }

        detectCycles(graph);
    }

    private void assignIds(TemplatePayload.Template t) {
        List<TemplatePayload.ColumnDefinition> cols = t.getReportData().getColumns();
        List<TemplatePayload.Row> rows = defaultList(t.getReportData().getRows());

        for (TemplatePayload.Row row : rows) {
            if (!StringUtils.hasText(row.getId())) {
                throw new BadRequestException("Row id is required before assigning cell ids");
            }
            List<TemplatePayload.Cell> cells = defaultList(row.getCells());
            for (int i = 0; i < cells.size(); i++) {
                TemplatePayload.Cell cell = cells.get(i);
                if (i >= cols.size()) {
                    throw new BadRequestException("Cell index exceeds column count in row " + row.getId());
                }
                if (!StringUtils.hasText(cell.getId())) {
                    String colId = cols.get(i).getId();
                    cell.setId("cell_" + row.getId() + "_" + colId);
                }
            }
        }
    }

    private void validateSchemaPermissions(Map<String, Set<ColumnUsage>> requirements) {
        Map<String, AllowedTablesDTO> allowedSchema = allowedTablesRepository.findAll().stream()
                .filter(t -> "Y".equalsIgnoreCase(t.getActive()))
                .map(AllowedTablesDTO::new)
                .collect(Collectors.toMap(dto -> dto.getTableName().toUpperCase(), dto -> dto));

        for (Map.Entry<String, Set<ColumnUsage>> tableReq : requirements.entrySet()) {
            String table = tableReq.getKey();
            AllowedTablesDTO tableDto = allowedSchema.get(table.toUpperCase());
            if (tableDto == null) {
                throw new BadRequestException("Table not whitelisted: " + table);
            }

            Map<String, AllowedColumnsDTO> columnMap = tableDto.getColumns().stream()
                    .collect(Collectors.toMap(c -> c.getColumnName().toUpperCase(), c -> c, (a, b) -> a));

            for (ColumnUsage usage : tableReq.getValue()) {
                AllowedColumnsDTO allowed = columnMap.get(usage.column.toUpperCase());
                if (allowed == null) {
                    throw new BadRequestException("Column not whitelisted: " + table + "." + usage.column);
                }
                if (usage.isSelectable && !"Y".equalsIgnoreCase(allowed.getSelectable())) {
                    throw new BadRequestException("Column is not selectable: " + table + "." + usage.column);
                }
                if (usage.isUsedInFilter && !"Y".equalsIgnoreCase(allowed.getFilterable())) {
                    throw new BadRequestException("Column is not filterable: " + table + "." + usage.column);
                }
                if (("DB_SUM".equals(usage.aggType) || "DB_AVG".equals(usage.aggType))
                        && !isNumericDataType(allowed.getDataType())) {
                    throw new BadRequestException("Aggregate " + usage.aggType + " requires numeric column: " + table + "." + usage.column);
                }
            }
        }
    }

    private void validateVariants(List<VariantDto> variants, Set<String> tablesUsedInTemplate) {
        Set<String> seenCodes = new HashSet<>();
        for (VariantDto variant : variants) {
            validateIdentifier(variant.getVariantCode(), "Invalid variant code");
            if (!seenCodes.add(variant.getVariantCode())) {
                throw new BadRequestException("Duplicate variant code: " + variant.getVariantCode());
            }

            for (VariantParamDto param : defaultList(variant.getParams())) {
                validateIdentifier(param.getParamName(), "Invalid variant param name");
                String type = normalize(param.getParamType());
                if (!ALLOWED_PARAM_TYPES.contains(type)) {
                    throw new BadRequestException("Invalid variant param type: " + param.getParamType());
                }
                if (StringUtils.hasText(param.getValidation())) {
                    try {
                        Pattern.compile(param.getValidation());
                    } catch (Exception e) {
                        throw new BadRequestException("Invalid variant validation regex for " + param.getParamName());
                    }
                }
            }

            for (FilterRuleDto rule : defaultList(variant.getFilterRules())) {
                String scope = normalize(rule.getScopeType());
                if (!ALLOWED_VARIANT_SCOPES.contains(scope)) {
                    throw new BadRequestException("Invalid variant scopeType: " + rule.getScopeType());
                }
                String operator = normalize(rule.getOperator());
                if (!ALLOWED_OPERATORS.contains(operator)) {
                    throw new BadRequestException("Invalid variant operator: " + rule.getOperator());
                }
                validateIdentifier(rule.getDbColumn(), "Invalid variant dbColumn");
                if ("TABLE".equals(scope)) {
                    String scopeValue = rule.getScopeValue();
                    if (!StringUtils.hasText(scopeValue) || !tablesUsedInTemplate.contains(scopeValue)) {
                        throw new BadRequestException("Variant scopeValue not used in template tables: " + scopeValue);
                    }
                }
            }
        }
    }

    private void addRequirement(Map<String, Set<ColumnUsage>> map, String table, ColumnUsage usage) {
        map.computeIfAbsent(table, key -> new HashSet<>()).add(usage);
    }

    private String normalize(String value) {
        return StringUtils.hasText(value) ? value.trim().toUpperCase() : null;
    }

    private String asString(Object value) {
        return value == null ? null : String.valueOf(value).trim();
    }

    @SuppressWarnings("unchecked")
    private Map<String, Object> castMap(Object obj) {
        if (obj == null) {
            return Collections.emptyMap();
        }
        if (!(obj instanceof Map<?, ?> map)) {
            throw new BadRequestException("Expected map object but got: " + obj.getClass().getSimpleName());
        }
        Map<String, Object> result = new LinkedHashMap<>();
        map.forEach((k, v) -> result.put(String.valueOf(k), v));
        return result;
    }

    private List<String> toStringList(Object value) {
        if (!(value instanceof List<?> list)) {
            return List.of();
        }
        List<String> out = new ArrayList<>();
        for (Object o : list) {
            if (!StringUtils.hasText(asString(o))) {
                continue;
            }
            out.add(asString(o));
        }
        return out;
    }

    private List<String> toOrderByParts(Object orderBy) {
        if (orderBy instanceof String str) {
            return List.of(str.split(","));
        }
        if (orderBy instanceof List<?> list) {
            return list.stream().filter(Objects::nonNull).map(String::valueOf).toList();
        }
        return List.of();
    }

    private Integer toInteger(Object value) {
        try {
            return Integer.parseInt(String.valueOf(value));
        } catch (Exception e) {
            throw new BadRequestException("Invalid numeric value: " + value);
        }
    }

    private Integer toNullableInteger(Object value) {
        if (value == null) {
            return null;
        }
        return toInteger(value);
    }

    private boolean containsSqlInjectionPattern(String value) {
        String normalized = value.toLowerCase();
        return normalized.contains(";") || normalized.contains("--") || normalized.contains("/*") || normalized.contains("'");
    }

    private void validateIdentifier(String value, String message) {
        if (!StringUtils.hasText(value) || !SQL_IDENTIFIER_PATTERN.matcher(value).matches()) {
            throw new BadRequestException(message + ": " + value);
        }
    }

    private String extractReportId(TemplatePayload payload) {
        String reportId = payload.getTemplate().getReportMeta() != null ? payload.getTemplate().getReportMeta().getReportId() : null;
        if (!StringUtils.hasText(reportId)) {
            throw new BadRequestException("reportId is required");
        }
        return reportId;
    }

    private void ensureCellReferenceExists(String ref, Map<String, TemplatePayload.Cell> allCells) {
        if (!allCells.containsKey(ref)) {
            throw new BadRequestException("Cell reference not found: " + ref);
        }
    }

    private boolean isNumeric(String token) {
        return token.matches("\\d+");
    }

    private void detectCycles(Map<String, Set<String>> graph) {
        Set<String> visited = new HashSet<>();
        Set<String> inStack = new HashSet<>();

        for (String node : graph.keySet()) {
            if (!visited.contains(node) && hasCycleDfs(node, graph, visited, inStack)) {
                throw new BadRequestException("Circular dependency detected in formula cells");
            }
        }
    }

    private boolean hasCycleDfs(String node, Map<String, Set<String>> graph, Set<String> visited, Set<String> inStack) {
        visited.add(node);
        inStack.add(node);
        for (String next : graph.getOrDefault(node, Set.of())) {
            if (!graph.containsKey(next)) {
                continue;
            }
            if (!visited.contains(next) && hasCycleDfs(next, graph, visited, inStack)) {
                return true;
            }
            if (inStack.contains(next)) {
                return true;
            }
        }
        inStack.remove(node);
        return false;
    }

    private boolean isNumericDataType(String dataType) {
        if (!StringUtils.hasText(dataType)) {
            return false;
        }
        String normalized = dataType.toUpperCase();
        return normalized.contains("NUMBER") || normalized.contains("DECIMAL");
    }

    private <T> List<T> defaultList(List<T> list) {
        return list == null ? List.of() : list;
    }

    private static class ValidationContext {
        long totalEstimatedSpecs = 0;
        Set<String> tablesUsed = new HashSet<>();
        Map<String, Set<ColumnUsage>> dbRequirements = new HashMap<>();
    }

    private static class ColumnUsage {
        String column;
        String aggType;
        boolean isUsedInFilter;
        boolean isSelectable;

        ColumnUsage(String column, String aggType, boolean isUsedInFilter, boolean isSelectable) {
            this.column = column;
            this.aggType = aggType;
            this.isUsedInFilter = isUsedInFilter;
            this.isSelectable = isSelectable;
        }

        @Override
        public boolean equals(Object o) {
            if (this == o) return true;
            if (o == null || getClass() != o.getClass()) return false;
            ColumnUsage that = (ColumnUsage) o;
            return isUsedInFilter == that.isUsedInFilter && isSelectable == that.isSelectable && Objects.equals(column, that.column) && Objects.equals(aggType, that.aggType);
        }

        @Override
        public int hashCode() {
            return Objects.hash(column, aggType, isUsedInFilter, isSelectable);
        }
    }
}










