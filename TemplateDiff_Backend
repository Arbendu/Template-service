package com.fincore.TemplateConfigurationService.controller;

import com.fasterxml.jackson.core.JsonProcessingException;
import com.fincore.TemplateConfigurationService.dto.*;
import com.fincore.TemplateConfigurationService.entity.ReportTemplate;
import com.fincore.TemplateConfigurationService.requests.dto.CancelTemplateRequestDto;
import com.fincore.TemplateConfigurationService.requests.dto.CreateTemplateRequestDto;
import com.fincore.TemplateConfigurationService.requests.dto.ProcessTemplateRequestDto;
import com.fincore.TemplateConfigurationService.requests.dto.TemplateRequestSummaryDto;
import com.fincore.TemplateConfigurationService.requests.entity.TemplateRequest;
import com.fincore.TemplateConfigurationService.requests.service.TemplateRequestService;
